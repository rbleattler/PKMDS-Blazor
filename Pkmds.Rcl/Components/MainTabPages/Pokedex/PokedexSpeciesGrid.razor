@inherits BasePkmdsComponent

@if (rows.Count > 0)
{
    <MudTextField @bind-Value="searchText"
                  Placeholder="Search species…"
                  Immediate
                  AdornmenT="@Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Clearable
                  Class="mb-2"/>

    <MudDataGrid T="@PokedexGridRow"
                 Items="@rows"
                 QuickFilter="@FilterRow"
                 Dense
                 Hover
                 Bordered
                 FixedHeader
                 Virtualize="true"
                 ItemSize="36"
                 RowClassFunc="@((_, i) => i % 2 != 0 ? "row-alt" : string.Empty)"
                 Height="calc(100vh - 460px)">

        <Columns>
            <PropertyColumn Property="@(r => r.SpeciesId)" Title="#"/>
            <PropertyColumn Property="@(r => r.Name)" Title="Species"/>
            <TemplateColumn Title="Seen" Sortable="false">
                <CellTemplate>
                    <MudCheckBox T="@bool"
                                 Value="@context.Item.IsSeen"
                                 ValueChanged="@(v => OnSeenChanged(context.Item, v))"/>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Caught" Sortable="false">
                <CellTemplate>
                    <MudCheckBox T="@bool"
                                 Value="@context.Item.IsCaught"
                                 ValueChanged="@(v => OnCaughtChanged(context.Item, v))"/>
                </CellTemplate>
            </TemplateColumn>
            @if (hasDetailedEditor)
            {
                <TemplateColumn Title="" Sortable="false">
                    <CellTemplate>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Size="@Size.Small"
                                       OnClick="@(() => OpenDetails(context.Item))"/>
                    </CellTemplate>
                </TemplateColumn>
            }
        </Columns>

        <NoRecordsContent>
            <MudText>No species match the search.</MudText>
        </NoRecordsContent>

    </MudDataGrid>
}
