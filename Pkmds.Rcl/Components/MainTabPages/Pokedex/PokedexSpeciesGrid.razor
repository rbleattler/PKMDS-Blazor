@inherits BasePkmdsComponent

@if (rows.Count > 0)
{
    <MudStack Row
              AlignItems="@AlignItems.Center"
              Wrap="@Wrap.Wrap"
              Spacing="2"
              Class="mb-2">
        <MudTextField @bind-Value="searchText"
                      Placeholder="Search species…"
                      Immediate
                      AdornmenT="@Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Clearable/>
        <MudButtonGroup Variant="@Variant.Outlined"
                        Size="@Size.Small">
            <MudButton Color="@(selectedStatusFilter == DexStatusFilter.All
                                  ? Color.Primary
                                  : Color.Default)"
                       OnClick="@(() => selectedStatusFilter = DexStatusFilter.All)">
                All
            </MudButton>
            <MudButton Color="@(selectedStatusFilter == DexStatusFilter.Seen
                                  ? Color.Primary
                                  : Color.Default)"
                       OnClick="@(() => selectedStatusFilter = DexStatusFilter.Seen)">
                Seen
            </MudButton>
            <MudButton Color="@(selectedStatusFilter == DexStatusFilter.Caught
                                  ? Color.Success
                                  : Color.Default)"
                       OnClick="@(() => selectedStatusFilter = DexStatusFilter.Caught)">
                Caught
            </MudButton>
            <MudButton Color="@(selectedStatusFilter == DexStatusFilter.Unseen
                                  ? Color.Warning
                                  : Color.Default)"
                       OnClick="@(() => selectedStatusFilter = DexStatusFilter.Unseen)">
                Unseen
            </MudButton>
            <MudButton Color="@(selectedStatusFilter == DexStatusFilter.SeenNotCaught
                                  ? Color.Info
                                  : Color.Default)"
                       OnClick="@(() => selectedStatusFilter = DexStatusFilter.SeenNotCaught)">
                Seen / Not Caught
            </MudButton>
        </MudButtonGroup>
        @if (regionalDexDefinitions.Count > 0)
        {
            <MudButtonGroup Variant="@Variant.Outlined"
                            Size="@Size.Small">
                <MudButton Color="@(selectedRegionalDexFilter == -1
                                      ? Color.Primary
                                      : Color.Default)"
                           OnClick="@(() => selectedRegionalDexFilter = -1)">
                    All Dexes
                </MudButton>
                @for (var i = 0; i < regionalDexDefinitions.Count; i++)
                {
                    var idx = i;
                    <MudButton Color="@(selectedRegionalDexFilter == idx
                                          ? Color.Primary
                                          : Color.Default)"
                               OnClick="@(() => selectedRegionalDexFilter = idx)">
                        @regionalDexDefinitions[idx].Name
                    </MudButton>
                }
            </MudButtonGroup>
        }
    </MudStack>

    <MudDataGrid T="@PokedexGridRow"
                 Items="@rows"
                 QuickFilter="@FilterRow"
                 Dense
                 Hover
                 Bordered
                 FixedHeader
                 Virtualize="true"
                 RowClassFunc="@((_, i) => i % 2 != 0
                                   ? "row-alt"
                                   : string.Empty)"
                 Class="pokedex-species-grid">

        <Columns>
            <PropertyColumn Property="@(r => r.SpeciesId)"
                            Title="#"/>
            @for (var col = 0; col < regionalDexDefinitions.Count; col++)
            {
                var colIdx = col;
                <TemplateColumn Title="@regionalDexDefinitions[colIdx].Name"
                                Sortable="true"
                                SortBy="@(r => RegionalIdForSort(r, colIdx))">
                    <CellTemplate>
                        @if (colIdx < context.Item.RegionalIds.Count && context.Item.RegionalIds[colIdx] != 0)
                        {
                            @context.Item.RegionalIds[colIdx]
                        }
                    </CellTemplate>
                </TemplateColumn>
            }
            <PropertyColumn Property="@(r => r.Name)"
                            Title="Species"/>
            <TemplateColumn Title="Seen"
                            Sortable="true"
                            SortBy="@(r => r.IsSeen)">
                <CellTemplate>
                    <MudCheckBox T="@bool"
                                 Value="@context.Item.IsSeen"
                                 ValueChanged="@(v => OnSeenChanged(context.Item, v))"/>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Caught"
                            Sortable="true"
                            SortBy="@(r => r.IsCaught)">
                <CellTemplate>
                    <MudCheckBox T="@bool"
                                 Value="@context.Item.IsCaught"
                                 ValueChanged="@(v => OnCaughtChanged(context.Item, v))"/>
                </CellTemplate>
            </TemplateColumn>
            @if (hasDetailedEditor)
            {
                <TemplateColumn Title=""
                                Sortable="false">
                    <CellTemplate>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Size="@Size.Small"
                                       OnClick="@(() => OpenDetails(context.Item))"/>
                    </CellTemplate>
                </TemplateColumn>
            }
        </Columns>

        <NoRecordsContent>
            <MudText>No species match the search.</MudText>
        </NoRecordsContent>

    </MudDataGrid>
}
