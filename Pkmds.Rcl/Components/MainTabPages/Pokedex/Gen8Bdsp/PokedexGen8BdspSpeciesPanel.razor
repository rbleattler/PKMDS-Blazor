@inherits BasePkmdsComponent

@if (AppState.SaveFile is SAV8BS sav8bs)
{
    var dex = sav8bs.Zukan;
    var formCount = Zukan8b.GetFormCount(SpeciesId);
    var formNames = formCount > 0
        ? FormConverter.GetFormList(SpeciesId, GameInfo.Strings.types, GameInfo.Strings.forms,
            GameInfo.GenderSymbolASCII, EntityContext.Gen8b).Take(formCount).ToArray()
        : [];

    <MudStack Spacing="3">

        @* State *@
        <MudSelect T="int"
                   Label="State"
                   Value="@((int)dex.GetState(SpeciesId))"
                   ValueChanged="@(v =>
                                 {
                                     dex.SetState(SpeciesId, (ZukanState8b)v);
                                     StateHasChanged();
                                 })"
                   Dense
                   Style="max-width:200px;">
            @foreach (var s in Enum.GetValues<ZukanState8b>())
            {
                <MudSelectItem Value="@((int)s)">@s</MudSelectItem>
            }
        </MudSelect>

        @* Gender × shiny flags *@
        <MudText Typo="@Typo.subtitle2">Gender / Shiny Seen</MudText>
        @{
            dex.GetGenderFlags(SpeciesId, out var m, out var f, out var ms, out var fs);
        }
        <MudStack Row
                  Spacing="2">
            <MudCheckBox T="bool"
                         Label="Male"
                         Value="@m"
                         ValueChanged="@(v => OnGenderFlagsChanged(dex, v, f, ms, fs))"/>
            <MudCheckBox T="bool"
                         Label="Female"
                         Value="@f"
                         ValueChanged="@(v => OnGenderFlagsChanged(dex, m, v, ms, fs))"/>
            <MudCheckBox T="bool"
                         Label="Male ★"
                         Value="@ms"
                         ValueChanged="@(v => OnGenderFlagsChanged(dex, m, f, v, fs))"/>
            <MudCheckBox T="bool"
                         Label="Female ★"
                         Value="@fs"
                         ValueChanged="@(v => OnGenderFlagsChanged(dex, m, f, ms, v))"/>
        </MudStack>

        @* Form flags *@
        @if (formCount > 0)
        {
            <MudText Typo="@Typo.subtitle2">Forms Seen</MudText>
            <MudSimpleTable Dense
                            Style="max-width:360px;">
                <thead>
                <tr>
                    <th>Form</th>
                    <th>Normal</th>
                    <th>Shiny</th>
                </tr>
                </thead>
                <tbody>
                @for (byte i = 0; i < formCount; i++)
                {
                    var fi = i;
                    var name = fi < formNames.Length
                        ? formNames[fi]
                        : $"Form {fi}";
                    <tr>
                        <td>@name</td>
                        <td>
                            <MudCheckBox T="bool"
                                         Value="@dex.GetHasFormFlag(SpeciesId, fi, false)"
                                         ValueChanged="@(v =>
                                                       {
                                                           dex.SetHasFormFlag(SpeciesId, fi, false, v);
                                                           StateHasChanged();
                                                       })"/>
                        </td>
                        <td>
                            <MudCheckBox T="bool"
                                         Value="@dex.GetHasFormFlag(SpeciesId, fi, true)"
                                         ValueChanged="@(v =>
                                                       {
                                                           dex.SetHasFormFlag(SpeciesId, fi, true, v);
                                                           StateHasChanged();
                                                       })"/>
                        </td>
                    </tr>
                }
                </tbody>
            </MudSimpleTable>
        }

        @* Language flags *@
        <MudText Typo="@Typo.subtitle2">Languages Obtained</MudText>
        <MudStack Row
                  Wrap="@Wrap.Wrap"
                  Spacing="1">
            @foreach (var (label, langId) in LanguageLabels)
            {
                var lid = (int)langId;
                <MudCheckBox T="bool"
                             Label="@label"
                             Value="@dex.GetLanguageFlag(SpeciesId, lid)"
                             ValueChanged="@(v =>
                                           {
                                               dex.SetLanguageFlag(SpeciesId, lid, v);
                                               StateHasChanged();
                                           })"/>
            }
        </MudStack>

    </MudStack>
}
