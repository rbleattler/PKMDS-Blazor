@inherits BasePkmdsComponent

@{
    Zukan6? dex = AppState.SaveFile switch
    {
        SAV6XY xy => xy.Zukan,
        SAV6AO ao => ao.Zukan,
        _ => null
    };
    var isOras = AppState.SaveFile is SAV6AO;
    var isXy = AppState.SaveFile is SAV6XY;
}

@if (dex is not null)
{
    <MudStack Spacing="3">

        @* Caught *@
        <MudCheckBox T="@bool"
                     Label="Caught"
                     Value="@dex.GetCaught(SpeciesId)"
                     ValueChanged="@(v =>
                                   {
                                       dex.SetCaught(SpeciesId, v);
                                       if (v) dex.SetSeen(SpeciesId, 0);
                                       StateHasChanged();
                                   })"/>

        @* Seen (4 regions) *@
        <MudText Typo="@Typo.subtitle2">Seen</MudText>
        <MudStack Row
                  Wrap="@Wrap.Wrap"
                  Spacing="1">
            @foreach (var (label, region) in SeenRegions)
            {
                var r = region;
                <MudCheckBox T="@bool"
                             Label="@label"
                             Disabled="@(!IsRegionValid(r))"
                             Value="@dex.GetSeen(SpeciesId, r)"
                             ValueChanged="@(v =>
                                           {
                                               dex.SetSeen(SpeciesId, r, v);
                                               StateHasChanged();
                                           })"/>
            }
        </MudStack>

        @* Displayed *@
        <MudText Typo="@Typo.subtitle2">Displayed Variant</MudText>
        <MudStack Row
                  Wrap="@Wrap.Wrap"
                  Spacing="1">
            @foreach (var (label, region) in SeenRegions)
            {
                var r = region;
                <MudCheckBox T="@bool"
                             Label="@label"
                             Disabled="@(!IsRegionValid(r))"
                             Value="@dex.GetDisplayed(SpeciesId, r)"
                             ValueChanged="@(v => OnDisplayedChanged(dex, r, v))"/>
            }
        </MudStack>

        @* Form flags *@
        @{
            var (formIndex, formCount) = dex.GetFormIndex(SpeciesId);
        }
        @if (formCount > 0)
        {
            const EntityContext ctx = EntityContext.Gen6;
            var formNames = FormConverter.GetFormList(SpeciesId, GameInfo.Strings.types,
                GameInfo.Strings.forms, GameInfo.GenderSymbolASCII, ctx);
            <MudText Typo="@Typo.subtitle2">Forms Seen</MudText>
            <MudSimpleTable Dense
                            Style="max-width:420px;">
                <thead>
                <tr>
                    <th>Form</th>
                    <th>Normal</th>
                    <th>Shiny</th>
                </tr>
                </thead>
                <tbody>
                @for (var i = 0; i < formCount; i++)
                {
                    var fi = formIndex + i;
                    var name = i < formNames.Length
                        ? formNames[i]
                        : $"Form {i}";
                    <tr>
                        <td>@name</td>
                        <td>
                            <MudCheckBox T="@bool"
                                         Value="@dex.GetFormSeen(fi, false)"
                                         ValueChanged="@(v =>
                                                       {
                                                           dex.SetFormSeen(fi, false, v);
                                                           StateHasChanged();
                                                       })"/>
                        </td>
                        <td>
                            <MudCheckBox T="@bool"
                                         Value="@dex.GetFormSeen(fi, true)"
                                         ValueChanged="@(v =>
                                                       {
                                                           dex.SetFormSeen(fi, true, v);
                                                           StateHasChanged();
                                                       })"/>
                        </td>
                    </tr>
                }
                </tbody>
            </MudSimpleTable>

            @* Forms Displayed — one form×shiny combo shown at a time (radio-group) *@
            <MudText Typo="@Typo.subtitle2">Forms Displayed</MudText>
            <MudSimpleTable Dense
                            Style="max-width:420px;">
                <thead>
                <tr>
                    <th>Form</th>
                    <th>Normal</th>
                    <th>Shiny</th>
                </tr>
                </thead>
                <tbody>
                @for (var i = 0; i < formCount; i++)
                {
                    var fi = formIndex + i;
                    var name = i < formNames.Length
                        ? formNames[i]
                        : $"Form {i}";
                    <tr>
                        <td>@name</td>
                        <td>
                            <MudCheckBox T="@bool"
                                         Value="@dex.GetFormFlag(fi, 2)"
                                         ValueChanged="@(v => OnFormDisplayedChanged(dex, formIndex, formCount, fi, 2, v))"/>
                        </td>
                        <td>
                            <MudCheckBox T="@bool"
                                         Value="@dex.GetFormFlag(fi, 3)"
                                         ValueChanged="@(v => OnFormDisplayedChanged(dex, formIndex, formCount, fi, 3, v))"/>
                        </td>
                    </tr>
                }
                </tbody>
            </MudSimpleTable>
        }

        @* XY-only: Foreign flag *@
        @if (isXy && AppState.SaveFile is SAV6XY xy && SpeciesId <= (ushort)Species.Genesect)
        {
            <MudCheckBox T="@bool"
                         Label="Foreign (obtained from trade/event outside this region)"
                         Value="@xy.Zukan.GetForeignFlag(SpeciesId)"
                         ValueChanged="@(v =>
                                       {
                                           xy.Zukan.SetForeignFlag(SpeciesId, v);
                                           StateHasChanged();
                                       })"/>
        }

        @* ORAS-only: DexNav Lv + Obtained count *@
        @if (isOras && AppState.SaveFile is SAV6AO ao)
        {
            <MudStack Row
                      Spacing="4"
                      AlignItems="@AlignItems.Center">
                <MudNumericField T="@ushort"
                                 Label="DexNav Lv"
                                 Value="@ao.Zukan.GetCountSeen(SpeciesId)"
                                 ValueChanged="@(v =>
                                               {
                                                   ao.Zukan.SetCountSeen(SpeciesId, v);
                                                   StateHasChanged();
                                               })"
                                 Min="0"
                                 Max="999"
                                 Style="max-width:130px;"/>
                <MudNumericField T="@ushort"
                                 Label="Obtained Count"
                                 Value="@ao.Zukan.GetCountObtained(SpeciesId)"
                                 ValueChanged="@(v =>
                                               {
                                                   ao.Zukan.SetCountObtained(SpeciesId, v);
                                                   StateHasChanged();
                                               })"
                                 Min="0"
                                 Max="9999"
                                 Style="max-width:150px;"/>
            </MudStack>
        }

        @* Spinda EC *@
        @if (SpeciesId == (ushort)Species.Spinda)
        {
            <MudText Typo="@Typo.subtitle2">Spinda PID</MudText>
            <MudTextField T="@string"
                          Value="@dex.Spinda.ToString("X8")"
                          ValueChanged="@(v => OnSpindaChanged(dex, v))"
                          Label="PID (hex)"
                          Immediate
                          Style="max-width:180px;"/>
        }

        @* Language flags *@
        <MudText Typo="@Typo.subtitle2">Languages Obtained</MudText>
        <MudStack Row
                  Wrap="@Wrap.Wrap"
                  Spacing="1">
            @foreach (var (label, langId) in LanguageLabels)
            {
                var lid = langId;
                <MudCheckBox T="@bool"
                             Label="@label"
                             Value="@dex.GetLanguageFlag(SpeciesId, lid)"
                             ValueChanged="@(v => dex.SetLanguageFlag(SpeciesId, lid, v))"/>
            }
        </MudStack>

    </MudStack>
}
