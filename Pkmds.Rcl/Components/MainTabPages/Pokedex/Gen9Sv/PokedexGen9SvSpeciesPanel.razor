@inherits BasePkmdsComponent

@if (AppState.SaveFile is SAV9SV sav9sv)
{
    var dex = sav9sv.Zukan.DexPaldea;
    var formCount = sav9sv.Personal.GetFormEntry(SpeciesId, 0).FormCount;
    var formNames = FormConverter.GetFormList(SpeciesId, GameInfo.Strings.types, GameInfo.Strings.forms,
        GameInfo.GenderSymbolASCII, EntityContext.Gen9);

    <MudStack Spacing="3">

        @* State *@
        <MudSelect T="uint"
                   Label="State"
                   Value="@dex.Get(SpeciesId).GetState()"
                   ValueChanged="@(v => { dex.Get(SpeciesId).SetState(v); StateHasChanged(); })"
                   Dense
                   Style="max-width:200px;">
            <MudSelectItem Value="@(0u)">Unknown</MudSelectItem>
            <MudSelectItem Value="@(1u)">Shown</MudSelectItem>
            <MudSelectItem Value="@(2u)">Seen</MudSelectItem>
            <MudSelectItem Value="@(3u)">Obtained</MudSelectItem>
        </MudSelect>

        @* Gender / shiny seen *@
        <MudText Typo="@Typo.subtitle2">Gender / Shiny Seen</MudText>
        <MudStack Row Spacing="2">
            <MudCheckBox T="bool" Label="Male" Value="@dex.Get(SpeciesId).GetIsGenderSeen(0)"
                         ValueChanged="@(v => { dex.Get(SpeciesId).SetIsGenderSeen(0, v); StateHasChanged(); })"/>
            <MudCheckBox T="bool" Label="Female" Value="@dex.Get(SpeciesId).GetIsGenderSeen(1)"
                         ValueChanged="@(v => { dex.Get(SpeciesId).SetIsGenderSeen(1, v); StateHasChanged(); })"/>
            <MudCheckBox T="bool" Label="Genderless" Value="@dex.Get(SpeciesId).GetIsGenderSeen(2)"
                         ValueChanged="@(v => { dex.Get(SpeciesId).SetIsGenderSeen(2, v); StateHasChanged(); })"/>
            <MudCheckBox T="bool" Label="★ Seen" Value="@dex.Get(SpeciesId).GetSeenIsShiny()"
                         ValueChanged="@(v => { dex.Get(SpeciesId).SetSeenIsShiny(v); StateHasChanged(); })"/>
        </MudStack>

        @* Forms seen *@
        @if (formCount > 1)
        {
            <MudText Typo="@Typo.subtitle2">Forms Seen</MudText>
            <MudSimpleTable Dense Style="max-width:300px;">
                <thead><tr><th>Form</th><th>Seen</th></tr></thead>
                <tbody>
                    @for (byte i = 0; i < formCount; i++)
                    {
                        var fi = i;
                        var name = fi < formNames.Length ? formNames[fi] : $"Form {fi}";
                        <tr>
                            <td>@name</td>
                            <td>
                                <MudCheckBox T="bool"
                                             Value="@dex.Get(SpeciesId).GetIsFormSeen(fi)"
                                             ValueChanged="@(v => { dex.Get(SpeciesId).SetIsFormSeen(fi, v); StateHasChanged(); })"/>
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        }

        @* Display *@
        <MudText Typo="@Typo.subtitle2">Display</MudText>
        <MudStack Row Spacing="2" AlignItems="AlignItems.Center">
            @if (formCount > 1)
            {
                <MudNumericField T="uint"
                                 Label="Form"
                                 Value="@dex.Get(SpeciesId).GetDisplayForm()"
                                 ValueChanged="@(v => { dex.Get(SpeciesId).SetDisplayForm(v); StateHasChanged(); })"
                                 Min="0" Max="@((uint)(formCount - 1))"
                                 Style="max-width:80px;"/>
            }
            <MudSelect T="uint"
                       Label="Gender"
                       Value="@dex.Get(SpeciesId).GetDisplayGender()"
                       ValueChanged="@(v => { dex.Get(SpeciesId).SetDisplayGender((int)v); StateHasChanged(); })"
                       Dense
                       Style="max-width:140px;">
                <MudSelectItem Value="@(0u)">Male</MudSelectItem>
                <MudSelectItem Value="@(1u)">Female</MudSelectItem>
                <MudSelectItem Value="@(2u)">Genderless</MudSelectItem>
            </MudSelect>
            <MudCheckBox T="bool" Label="★ Shiny" Value="@dex.Get(SpeciesId).GetDisplayIsShiny()"
                         ValueChanged="@(v => { dex.Get(SpeciesId).SetDisplayIsShiny(v); StateHasChanged(); })"/>
            <MudCheckBox T="bool" Label="New" Value="@dex.Get(SpeciesId).GetDisplayIsNew()"
                         ValueChanged="@(v => { dex.Get(SpeciesId).SetDisplayIsNew(v); StateHasChanged(); })"/>
        </MudStack>

        @* Language flags *@
        <MudText Typo="@Typo.subtitle2">Languages Obtained</MudText>
        <MudStack Row Wrap="@Wrap.Wrap" Spacing="1">
            @foreach (var (label, langId) in _languageLabels)
            {
                var lid = langId;
                <MudCheckBox T="bool"
                             Label="@label"
                             Value="@dex.Get(SpeciesId).GetLanguageFlag(lid)"
                             ValueChanged="@(v => { dex.Get(SpeciesId).SetLanguageFlag(lid, v); StateHasChanged(); })"/>
            }
        </MudStack>

    </MudStack>
}

@code {
    private static readonly (string Label, int LangId)[] _languageLabels =
    [
        ("JPN", (int)LanguageID.Japanese), ("ENG", (int)LanguageID.English), ("FRE", (int)LanguageID.French),
        ("ITA", (int)LanguageID.Italian), ("GER", (int)LanguageID.German), ("SPA", (int)LanguageID.Spanish),
        ("KOR", (int)LanguageID.Korean), ("CHS", (int)LanguageID.ChineseS), ("CHT", (int)LanguageID.ChineseT),
    ];
}
