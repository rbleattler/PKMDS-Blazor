@inherits BasePkmdsComponent

@if (AppState.SaveFile is SAV8LA sav8La)
{
    var dex = sav8La.Blocks.PokedexSave;
    var hisuiDexIndex = PokedexSave8a.GetDexIndex(PokedexType8a.Hisui, SpeciesId);
    var pi = sav8La.Personal.GetFormEntry(SpeciesId, 0);
    var formCount = pi.FormCount;
    var formNames = FormConverter.GetFormList(SpeciesId, GameInfo.Strings.types, GameInfo.Strings.forms,
        GameInfo.GenderSymbolASCII, EntityContext.Gen8a);

    // Collect forms with statistics storage
    var storedForms = Enumerable.Range(0, formCount)
        .Select(i => (byte)i)
        .Where(f => dex.HasFormStorage(SpeciesId, f) && !dex.IsBlacklisted(SpeciesId, f))
        .ToList();

    <MudStack Spacing="3">

        @* Status *@
        <MudText Typo="@Typo.subtitle2">Status</MudText>
        <MudStack Row
                  Spacing="2">
            <MudTooltip Text="@(dex.HasPokeEverBeenUpdated(SpeciesId) ? "Cannot be unset once seen" : "Mark as seen")">
                <MudCheckBox T="@bool"
                             Label="Seen"
                             Value="@dex.HasPokeEverBeenUpdated(SpeciesId)"
                             ValueChanged="@(v =>
                                           {
                                               if (v) dex.SetPokeHasBeenUpdated(SpeciesId);
                                               StateHasChanged();
                                           })"
                             Disabled="@dex.HasPokeEverBeenUpdated(SpeciesId)"/>
            </MudTooltip>
            <MudTooltip Text="Automatically set when research points reach 100">
                <MudCheckBox T="@bool"
                             Label="Complete (100%)"
                             Value="@(dex.ComputeResearchRateFromTasks(SpeciesId, hisuiDexIndex) >= 100)"
                             Disabled/>
            </MudTooltip>
            <MudTooltip Text="Automatically set when all research tasks reach max level">
                <MudCheckBox T="@bool"
                             Label="Perfect"
                             Value="@dex.ComputeIsPerfect(SpeciesId, hisuiDexIndex)"
                             Disabled/>
            </MudTooltip>
            <MudCheckBox T="@bool"
                         Label="Solitude"
                         Value="@dex.GetSolitudeComplete(SpeciesId)"
                         ValueChanged="@(v =>
                                       {
                                           dex.SetSolitudeComplete(SpeciesId, v);
                                           StateHasChanged();
                                       })"/>
        </MudStack>

        @* Per-form flags *@
        @if (storedForms.Count > 0)
        {
            @* Bit 0=Male, 1=Female, 2=Alpha Male, 3=Alpha Female,
               4=Shiny Male, 5=Shiny Female, 6=Shiny Alpha Male, 7=Shiny Alpha Female *@
            string[] variantLabels = ["Male", "Female", "Alpha Male", "Alpha Female", "Shiny Male", "Shiny Female", "Shiny Alpha Male", "Shiny Alpha Female"];

            @foreach (var (flagLabel, flagIndex) in new[] { ("Seen in the Wild", 0), ("Obtained", 1), ("Caught in the Wild", 2) })
            {
                <MudText Typo="@Typo.subtitle2">@flagLabel</MudText>
                <MudSimpleTable Dense>
                    <thead>
                    <tr>
                        <th style="min-width:80px;">Form</th>
                        @foreach (var vl in variantLabels)
                        {
                            <th style="text-align:center;">@vl</th>
                        }
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var form in storedForms)
                    {
                        var f = form;
                        var seenWild = dex.GetPokeSeenInWildFlags(SpeciesId, f);
                        var obtained = dex.GetPokeObtainFlags(SpeciesId, f);
                        var caughtWild = dex.GetPokeCaughtInWildFlags(SpeciesId, f);
                        var name = f < formNames.Length ? formNames[f] : $"Form {f}";
                        <tr>
                            <td>@name</td>
                            @for (var b = 0; b < 8; b++)
                            {
                                var bit = b;
                                <td style="text-align:center;">
                                    @if (flagIndex == 0)
                                    {
                                        <MudCheckBox T="@bool"
                                                     Value="@((seenWild & 1 << bit) != 0)"
                                                     ValueChanged="@(v => OnSeenFlagChanged(dex, f, bit, v))"/>
                                    }
                                    else if (flagIndex == 1)
                                    {
                                        <MudCheckBox T="@bool"
                                                     Value="@((obtained & 1 << bit) != 0)"
                                                     ValueChanged="@(v => OnObtainFlagChanged(dex, f, bit, v))"/>
                                    }
                                    else
                                    {
                                        <MudCheckBox T="@bool"
                                                     Value="@((caughtWild & 1 << bit) != 0)"
                                                     ValueChanged="@(v => OnCaughtFlagChanged(dex, f, bit, v))"/>
                                    }
                                </td>
                            }
                        </tr>
                    }
                    </tbody>
                </MudSimpleTable>
            }
        }

        @* Display options *@
        <MudText Typo="@Typo.subtitle2">Display</MudText>
        <MudStack Row
                  Spacing="2"
                  AlignItems="AlignItems.Center">
            @if (storedForms.Count > 1)
            {
                @* Use MudSelect over actual form IDs so filtered/blacklisted forms never make the
                   current value exceed the control's max or write an incorrect form id. *@
                <MudSelect T="@byte"
                           Label="Form"
                           Value="@((byte)dex.GetSelectedForm(SpeciesId))"
                           ValueChanged="@(v => OnDisplayChanged(dex, v, dex.GetSelectedGender1(SpeciesId), dex.GetSelectedShiny(SpeciesId), dex.GetSelectedAlpha(SpeciesId)))"
                           Dense
                           Style="max-width:140px;">
                    @foreach (var sf in storedForms)
                    {
                        var sfv = sf;
                        var sfn = sfv < formNames.Length
                            ? formNames[sfv]
                            : $"Form {sfv}";
                        <MudSelectItem Value="@sfv">@sfn</MudSelectItem>
                    }
                </MudSelect>
            }
            @if (PokedexSave8a.HasMultipleGenders(SpeciesId))
            {
                <MudCheckBox T="@bool"
                             Label="Female"
                             Value="@dex.GetSelectedGender1(SpeciesId)"
                             ValueChanged="@(v => OnDisplayChanged(dex, (byte)dex.GetSelectedForm(SpeciesId), v, dex.GetSelectedShiny(SpeciesId), dex.GetSelectedAlpha(SpeciesId)))"/>
            }
            <MudCheckBox T="@bool"
                         Label="Shiny"
                         Value="@dex.GetSelectedShiny(SpeciesId)"
                         ValueChanged="@(v => OnDisplayChanged(dex, (byte)dex.GetSelectedForm(SpeciesId), dex.GetSelectedGender1(SpeciesId), v, dex.GetSelectedAlpha(SpeciesId)))"/>
            <MudCheckBox T="@bool"
                         Label="Alpha"
                         Value="@dex.GetSelectedAlpha(SpeciesId)"
                         ValueChanged="@(v => OnDisplayChanged(dex, (byte)dex.GetSelectedForm(SpeciesId), dex.GetSelectedGender1(SpeciesId), dex.GetSelectedShiny(SpeciesId), v))"/>
        </MudStack>

        @* Size stats (first stored form) — only shown when at least one form has size storage *@
        @{
            var firstForm = storedForms.Count > 0
                ? storedForms[0]
                : (byte)0;
            var hasMax = false;
            float minH = 0, maxH = 0, minW = 0, maxW = 0;
            if (storedForms.Count > 0)
                dex.GetSizeStatistics(SpeciesId, firstForm, out hasMax, out minH, out maxH, out minW, out maxW);
        }
        @if (storedForms.Count > 0)
        {
            <MudText Typo="@Typo.subtitle2">Size Records (Form @firstForm)</MudText>
            <MudStack Row
                      Spacing="2"
                      AlignItems="AlignItems.Center">
                <MudCheckBox T="@bool"
                             Label="Has Max"
                             Value="@hasMax"
                             ValueChanged="@(v => dex.SetSizeStatistics(SpeciesId, firstForm, v, minH, maxH, minW, maxW))"/>
                <MudNumericField T="@float"
                                 Label="Min Height"
                                 Value="@minH"
                                 ValueChanged="@(v => dex.SetSizeStatistics(SpeciesId, firstForm, hasMax, v, maxH, minW, maxW))"
                                 Format="F4"
                                 Style="max-width:120px;"/>
                <MudNumericField T="@float"
                                 Label="Max Height"
                                 Value="@maxH"
                                 ValueChanged="@(v => dex.SetSizeStatistics(SpeciesId, firstForm, hasMax, minH, v, minW, maxW))"
                                 Format="F4"
                                 Style="max-width:120px;"/>
                <MudNumericField T="@float"
                                 Label="Min Weight"
                                 Value="@minW"
                                 ValueChanged="@(v => dex.SetSizeStatistics(SpeciesId, firstForm, hasMax, minH, maxH, v, maxW))"
                                 Format="F4"
                                 Style="max-width:120px;"/>
                <MudNumericField T="@float"
                                 Label="Max Weight"
                                 Value="@maxW"
                                 ValueChanged="@(v => dex.SetSizeStatistics(SpeciesId, firstForm, hasMax, minH, maxH, minW, v))"
                                 Format="F4"
                                 Style="max-width:120px;"/>
            </MudStack>
        }

    </MudStack>
}
