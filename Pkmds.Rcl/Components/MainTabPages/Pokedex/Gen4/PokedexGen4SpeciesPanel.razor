@inherits BasePkmdsComponent

@if (AppState.SaveFile is SAV4 sav4)
{
    var dex = sav4.Dex;
    var pi = sav4.Personal[SpeciesId];

    <MudStack Spacing="3">

        @* Caught / Seen *@
        <MudStack Row Spacing="4">
            <MudCheckBox T="bool"
                         Label="Caught"
                         Value="@dex.GetCaught(SpeciesId)"
                         ValueChanged="@(v => OnCaughtChanged(dex, v))"/>
            <MudCheckBox T="bool"
                         Label="Seen"
                         Value="@dex.GetSeen(SpeciesId)"
                         ValueChanged="@(v => OnSeenChanged(dex, v))"/>
        </MudStack>

        @* Gender Seen *@
        @{
            var gr = pi.Gender;
            var isMaleOnly = gr == PersonalInfo.RatioMagicMale;
            var isFemaleOnly = gr == PersonalInfo.RatioMagicFemale;
            var isGenderless = gr == PersonalInfo.RatioMagicGenderless;
        }
        <MudText Typo="@Typo.subtitle2">Gender Seen</MudText>
        @if (isGenderless)
        {
            <MudText Typo="@Typo.body2">Genderless</MudText>
        }
        else if (isMaleOnly)
        {
            <MudText Typo="@Typo.body2">Male only</MudText>
        }
        else if (isFemaleOnly)
        {
            <MudText Typo="@Typo.body2">Female only</MudText>
        }
        else
        {
            @* Dual gender: first bit 0=male, 1=female; second bit 0=male, 1=female *@
            var first = dex.GetSeenGenderFirst(SpeciesId); // 0=male, 1=female
            var single = dex.GetSeenSingleGender(SpeciesId);
            <MudStack Row Spacing="2" AlignItems="@AlignItems.Center">
                <MudText Typo="@Typo.body2">First seen: </MudText>
                <MudSelect T="@int"
                           Value="@first"
                           ValueChanged="@(v => OnFirstGenderChanged(dex, v))"
                           Dense
                           Style="min-width:110px;">
                    <MudSelectItem Value="@((int)0)">Male</MudSelectItem>
                    <MudSelectItem Value="@((int)1)">Female</MudSelectItem>
                </MudSelect>
                <MudCheckBox T="bool"
                             Label="Both genders seen"
                             Value="@(!single)"
                             ValueChanged="@(v => OnBothGendersChanged(dex, first, v))"/>
            </MudStack>
        }

        @* Form flags *@
        @{
            var forms = dex.GetForms(SpeciesId);
            var formNames = Zukan4.GetFormNames4Dex(SpeciesId);
        }
        @if (forms.Length > 0 && formNames.Length > 1)
        {
            <MudText Typo="@Typo.subtitle2">Forms Seen</MudText>
            <MudStack Row Wrap="@Wrap.Wrap" Spacing="1">
                @for (var i = 0; i < formNames.Length; i++)
                {
                    var formIdx = (byte)i;
                    var isSeen = SpeciesId == (ushort)Species.Unown
                        ? dex.GetUnownForm(formIdx)
                        : forms.Contains(formIdx);
                    <MudCheckBox T="bool"
                                 Label="@formNames[formIdx]"
                                 Value="@isSeen"
                                 ValueChanged="@(v => OnFormChanged(dex, formIdx, v))"/>
                }
            </MudStack>
        }

        @* Spinda PID *@
        @if (SpeciesId == (ushort)Species.Spinda)
        {
            <MudText Typo="@Typo.subtitle2">Spinda PID</MudText>
            <MudTextField T="string"
                          Value="@dex.SpindaPID.ToString("X8")"
                          ValueChanged="@(v => OnSpindaPidChanged(dex, v))"
                          Label="PID (hex)"
                          Immediate
                          Style="max-width:180px;"/>
        }

        @* Language flags *@
        @if (dex.HasLanguage(SpeciesId))
        {
            <MudText Typo="@Typo.subtitle2">Languages Obtained</MudText>
            <MudStack Row Wrap="@Wrap.Wrap" Spacing="1">
                @foreach (var (label, idx) in _languageLabels)
                {
                    var langIdx = idx;
                    <MudCheckBox T="bool"
                                 Label="@label"
                                 Value="@dex.GetLanguageBitIndex(SpeciesId, langIdx)"
                                 ValueChanged="@(v => dex.SetLanguageBitIndex(SpeciesId, langIdx, v))"/>
                }
            </MudStack>
        }

    </MudStack>
}

@code {
    // Gen 4 bit order: JPN=0, ENG=1, FRE=2, ITA=3, GER=4, SPA=5
    // (Zukan4.GetGen4LanguageBitIndex handles the LanguageID → bit index mapping)
    private static readonly (string Label, int Index)[] _languageLabels =
    [
        ("JPN", 0), ("ENG", 1), ("FRE", 2), ("ITA", 3), ("GER", 4), ("SPA", 5),
    ];
}
