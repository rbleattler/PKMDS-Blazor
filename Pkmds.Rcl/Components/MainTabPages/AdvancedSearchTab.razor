@inherits RefreshAwareComponent

<MudStack Class="pa-2"
          Spacing="3">

    @if (AppState.SaveFile is null)
    {
        <MudAlert Severity="@Severity.Info">No save file is loaded.</MudAlert>
    }
    else
    {
        <MudGrid>

            @* ── Filter panel ── *@
            <MudItem xs="12"
                     md="5">
                <MudStack Spacing="2"
                          Class="search-filter-panel">

                    <div class="search-filter-panel-scroll">

                        @* Saved filters *@
                        <MudExpansionPanels Dense>
                            <MudExpansionPanel Text="Saved Filters">
                                <MudStack Row
                                          Spacing="2"
                                          AlignItems="@AlignItems.Center"
                                          Wrap="@Wrap.Wrap">
                                    <MudSelect T="@string"
                                               Label="Load filter"
                                               Value="@selectedSavedFilter"
                                               ValueChanged="@LoadSavedFilter"
                                               Style="min-width: 160px;">
                                        <MudSelectItem T="@string"
                                                       Value="@(default(string))">— none —
                                        </MudSelectItem>
                                        @foreach (var name in savedFilters.Keys)
                                        {
                                            <MudSelectItem T="@string"
                                                           Value="@name">@name</MudSelectItem>
                                        }
                                    </MudSelect>
                                    <MudTextField @bind-Value="@saveFilterName"
                                                  Label="Save as"
                                                  Style="min-width: 120px;"/>
                                    <MudButton Size="@Size.Small"
                                               Variant="@Variant.Filled"
                                               Color="@Color.Primary"
                                               OnClick="@SaveCurrentFilterAsync">
                                        Save
                                    </MudButton>
                                    <MudButton Size="@Size.Small"
                                               Variant="@Variant.Outlined"
                                               Color="@Color.Error"
                                               OnClick="@DeleteSavedFilterAsync"
                                               Disabled="@(selectedSavedFilter is null)">
                                        Delete
                                    </MudButton>
                                </MudStack>
                            </MudExpansionPanel>
                        </MudExpansionPanels>

                        @* Filter sections *@
                        <MudExpansionPanels MultiExpansion
                                            Dense>

                            @* ── Basic ── *@
                            <MudExpansionPanel Text="Basic">
                                <MudStack Spacing="2">

                                    <MudAutocomplete T="@ComboItem"
                                                     Label="Species"
                                                     Value="@speciesItem"
                                                     ValueChanged="@(v => speciesItem = v)"
                                                     SearchFunc="@SearchSpeciesAsync"
                                                     ToStringFunc="@SpeciesItemToString"
                                                     Clearable
                                                     ResetValueOnEmptyText/>

                                    <MudGrid Spacing="2">
                                        <MudItem xs="6">
                                            <MudSelect T="@(bool?)"
                                                       Label="Shiny"
                                                       @bind-Value="@isShiny"
                                                       Clearable>
                                                <MudSelectItem T="@(bool?)"
                                                               Value="@((bool?)null)">Any
                                                </MudSelectItem>
                                                <MudSelectItem T="@(bool?)"
                                                               Value="@true">Shiny only
                                                </MudSelectItem>
                                                <MudSelectItem T="@(bool?)"
                                                               Value="@false">Non-shiny only
                                                </MudSelectItem>
                                            </MudSelect>
                                        </MudItem>
                                        <MudItem xs="6">
                                            <MudSelect T="@(bool?)"
                                                       Label="Egg"
                                                       @bind-Value="@isEgg"
                                                       Clearable>
                                                <MudSelectItem T="@(bool?)"
                                                               Value="@((bool?)null)">Any
                                                </MudSelectItem>
                                                <MudSelectItem T="@(bool?)"
                                                               Value="@true">Eggs only
                                                </MudSelectItem>
                                                <MudSelectItem T="@(bool?)"
                                                               Value="@false">Non-eggs only
                                                </MudSelectItem>
                                            </MudSelect>
                                        </MudItem>
                                    </MudGrid>

                                    <MudGrid Spacing="2">
                                        <MudItem xs="6">
                                            <MudSelect T="@(int?)"
                                                       Label="Gender"
                                                       @bind-Value="@gender"
                                                       Clearable>
                                                <MudSelectItem T="@(int?)"
                                                               Value="@((int?)null)">Any
                                                </MudSelectItem>
                                                <MudSelectItem T="@(int?)"
                                                               Value="@((int?)0)">Male
                                                </MudSelectItem>
                                                <MudSelectItem T="@(int?)"
                                                               Value="@((int?)1)">Female
                                                </MudSelectItem>
                                                <MudSelectItem T="@(int?)"
                                                               Value="@(-1)">Genderless
                                                </MudSelectItem>
                                            </MudSelect>
                                        </MudItem>
                                        <MudItem xs="6">
                                            <MudSelect T="@(int?)"
                                                       Label="Nature"
                                                       @bind-Value="@nature"
                                                       Clearable>
                                                <MudSelectItem T="@(int?)"
                                                               Value="@((int?)null)">Any
                                                </MudSelectItem>
                                                @foreach (var n in GameInfo.FilteredSources.Natures)
                                                {
                                                    <MudSelectItem T="@(int?)"
                                                                   Value="@n.Value">@n.Text</MudSelectItem>
                                                }
                                            </MudSelect>
                                        </MudItem>
                                    </MudGrid>

                                    <MudGrid Spacing="2">
                                        <MudItem xs="6">
                                            <MudSelect T="@(int?)"
                                                       Label="Type 1"
                                                       @bind-Value="@type1"
                                                       Clearable>
                                                <MudSelectItem T="@(int?)"
                                                               Value="@((int?)null)">Any
                                                </MudSelectItem>
                                                @for (var i = 0; i < 18; i++)
                                                {
                                                    var typeIndex = i;
                                                    <MudSelectItem T="@(int?)"
                                                                   Value="@typeIndex">
                                                        @GameInfo.Strings.Types[typeIndex]
                                                    </MudSelectItem>
                                                }
                                            </MudSelect>
                                        </MudItem>
                                        <MudItem xs="6">
                                            <MudSelect T="@(int?)"
                                                       Label="Type 2"
                                                       @bind-Value="@type2"
                                                       Clearable>
                                                <MudSelectItem T="@(int?)"
                                                               Value="@((int?)null)">Any
                                                </MudSelectItem>
                                                @for (var i = 0; i < 18; i++)
                                                {
                                                    var typeIndex = i;
                                                    <MudSelectItem T="@(int?)"
                                                                   Value="@typeIndex">
                                                        @GameInfo.Strings.Types[typeIndex]
                                                    </MudSelectItem>
                                                }
                                            </MudSelect>
                                        </MudItem>
                                    </MudGrid>

                                    <MudSelect T="@(bool?)"
                                               Label="Legal status"
                                               @bind-Value="@isLegal"
                                               Clearable>
                                        <MudSelectItem T="@(bool?)"
                                                       Value="@((bool?)null)">Any
                                        </MudSelectItem>
                                        <MudSelectItem T="@(bool?)"
                                                       Value="@true">Legal only
                                        </MudSelectItem>
                                        <MudSelectItem T="@(bool?)"
                                                       Value="@false">Illegal only
                                        </MudSelectItem>
                                    </MudSelect>

                                </MudStack>
                            </MudExpansionPanel>

                            @* ── Appearance ── *@
                            <MudExpansionPanel Text="Appearance">
                                <MudStack Spacing="2">

                                    @{
                                        var formList = GetFormList();
                                    }
                                    @if (formList.Count > 0)
                                    {
                                        <MudSelect T="@(byte?)"
                                                   Label="Form"
                                                   @bind-Value="@form"
                                                   Clearable>
                                            <MudSelectItem T="@(byte?)"
                                                           Value="@((byte?)null)">Any
                                            </MudSelectItem>
                                            @for (byte i = 0; i < formList.Count; i++)
                                            {
                                                var formIndex = i;
                                                var formName = formList[formIndex];
                                                if (string.IsNullOrEmpty(formName))
                                                {
                                                    continue;
                                                }
                                                <MudSelectItem T="@(byte?)"
                                                               Value="@((byte?)formIndex)">
                                                    @formName
                                                </MudSelectItem>
                                            }
                                        </MudSelect>
                                    }
                                    else if (speciesItem is not { Value: > 0 })
                                    {
                                        <MudText Typo="@Typo.caption">
                                            Pick a species to enable form filtering.
                                        </MudText>
                                    }

                                    @if (SaveSupportsTeraType())
                                    {
                                        <MudSelect T="@(int?)"
                                                   Label="Tera Type"
                                                   @bind-Value="@teraType"
                                                   Clearable>
                                            <MudSelectItem T="@(int?)"
                                                           Value="@((int?)null)">Any
                                            </MudSelectItem>
                                            @for (var i = 0; i < 18; i++)
                                            {
                                                var typeIndex = i;
                                                <MudSelectItem T="@(int?)"
                                                               Value="@typeIndex">
                                                    @GameInfo.Strings.Types[typeIndex]
                                                </MudSelectItem>
                                            }
                                            <MudSelectItem T="@(int?)"
                                                           Value="@((int?)TeraTypeUtil.Stellar)">
                                                @GameInfo.Strings.Types[TeraTypeUtil.StellarTypeDisplayStringIndex]
                                            </MudSelectItem>
                                        </MudSelect>
                                    }

                                    @if (SaveSupportsFavorite())
                                    {
                                        <MudSelect T="@(bool?)"
                                                   Label="Favorite"
                                                   @bind-Value="@isFavorite"
                                                   Clearable>
                                            <MudSelectItem T="@(bool?)"
                                                           Value="@((bool?)null)">Any
                                            </MudSelectItem>
                                            <MudSelectItem T="@(bool?)"
                                                           Value="@true">Favorites only
                                            </MudSelectItem>
                                            <MudSelectItem T="@(bool?)"
                                                           Value="@false">Non-favorites only
                                            </MudSelectItem>
                                        </MudSelect>
                                    }

                                    @if (SaveSupportsAlpha())
                                    {
                                        <MudSelect T="@(bool?)"
                                                   Label="Alpha"
                                                   @bind-Value="@isAlpha"
                                                   Clearable>
                                            <MudSelectItem T="@(bool?)"
                                                           Value="@((bool?)null)">Any
                                            </MudSelectItem>
                                            <MudSelectItem T="@(bool?)"
                                                           Value="@true">Alphas only
                                            </MudSelectItem>
                                            <MudSelectItem T="@(bool?)"
                                                           Value="@false">Non-alphas only
                                            </MudSelectItem>
                                        </MudSelect>
                                    }

                                    @if (SaveSupportsShadow())
                                    {
                                        <MudSelect T="@(bool?)"
                                                   Label="Shadow"
                                                   @bind-Value="@isShadow"
                                                   Clearable>
                                            <MudSelectItem T="@(bool?)"
                                                           Value="@((bool?)null)">Any
                                            </MudSelectItem>
                                            <MudSelectItem T="@(bool?)"
                                                           Value="@true">Shadow only
                                            </MudSelectItem>
                                            <MudSelectItem T="@(bool?)"
                                                           Value="@false">Non-shadow only
                                            </MudSelectItem>
                                        </MudSelect>
                                    }

                                    @if (SaveSupportsGigantamax())
                                    {
                                        <MudSelect T="@(bool?)"
                                                   Label="Gigantamax factor"
                                                   @bind-Value="@canGigantamax"
                                                   Clearable>
                                            <MudSelectItem T="@(bool?)"
                                                           Value="@((bool?)null)">Any
                                            </MudSelectItem>
                                            <MudSelectItem T="@(bool?)"
                                                           Value="@true">Gigantamax-capable only
                                            </MudSelectItem>
                                            <MudSelectItem T="@(bool?)"
                                                           Value="@false">Non-Gigantamax only
                                            </MudSelectItem>
                                        </MudSelect>
                                    }

                                    @if (SaveSupportsDynamaxLevel())
                                    {
                                        <MudNumericField T="@(byte?)"
                                                         Label="Min Dynamax level"
                                                         @bind-Value="@dynamaxLevelMin"
                                                         Min="0"
                                                         Max="10"/>
                                    }

                                </MudStack>
                            </MudExpansionPanel>

                            @* ── Stats ── *@
                            <MudExpansionPanel Text="Stats">
                                <MudStack Spacing="2">

                                    <MudText Typo="@Typo.subtitle2">Level range</MudText>
                                    <MudGrid Spacing="2">
                                        <MudItem xs="6">
                                            <MudNumericField T="@(int?)"
                                                             Label="Min level"
                                                             @bind-Value="@levelMin"
                                                             Min="1"
                                                             Max="100"/>
                                        </MudItem>
                                        <MudItem xs="6">
                                            <MudNumericField T="@(int?)"
                                                             Label="Max level"
                                                             @bind-Value="@levelMax"
                                                             Min="1"
                                                             Max="100"/>
                                        </MudItem>
                                    </MudGrid>

                                    <MudText Typo="@Typo.subtitle2">IV floors (0–31)</MudText>
                                    <MudGrid Spacing="2">
                                        <MudItem xs="4">
                                            <MudNumericField T="@(int?)"
                                                             Label="HP"
                                                             @bind-Value="@hpIvMin"
                                                             Min="0"
                                                             Max="31"/>
                                        </MudItem>
                                        <MudItem xs="4">
                                            <MudNumericField T="@(int?)"
                                                             Label="Atk"
                                                             @bind-Value="@atkIvMin"
                                                             Min="0"
                                                             Max="31"/>
                                        </MudItem>
                                        <MudItem xs="4">
                                            <MudNumericField T="@(int?)"
                                                             Label="Def"
                                                             @bind-Value="@defIvMin"
                                                             Min="0"
                                                             Max="31"/>
                                        </MudItem>
                                        <MudItem xs="4">
                                            <MudNumericField T="@(int?)"
                                                             Label="SpA"
                                                             @bind-Value="@spaIvMin"
                                                             Min="0"
                                                             Max="31"/>
                                        </MudItem>
                                        <MudItem xs="4">
                                            <MudNumericField T="@(int?)"
                                                             Label="SpD"
                                                             @bind-Value="@spdIvMin"
                                                             Min="0"
                                                             Max="31"/>
                                        </MudItem>
                                        <MudItem xs="4">
                                            <MudNumericField T="@(int?)"
                                                             Label="Spe"
                                                             @bind-Value="@speIvMin"
                                                             Min="0"
                                                             Max="31"/>
                                        </MudItem>
                                    </MudGrid>

                                    <MudText Typo="@Typo.subtitle2">EV floors (0–252)</MudText>
                                    <MudGrid Spacing="2">
                                        <MudItem xs="4">
                                            <MudNumericField T="@(int?)"
                                                             Label="HP"
                                                             @bind-Value="@hpEvMin"
                                                             Min="0"
                                                             Max="252"/>
                                        </MudItem>
                                        <MudItem xs="4">
                                            <MudNumericField T="@(int?)"
                                                             Label="Atk"
                                                             @bind-Value="@atkEvMin"
                                                             Min="0"
                                                             Max="252"/>
                                        </MudItem>
                                        <MudItem xs="4">
                                            <MudNumericField T="@(int?)"
                                                             Label="Def"
                                                             @bind-Value="@defEvMin"
                                                             Min="0"
                                                             Max="252"/>
                                        </MudItem>
                                        <MudItem xs="4">
                                            <MudNumericField T="@(int?)"
                                                             Label="SpA"
                                                             @bind-Value="@spaEvMin"
                                                             Min="0"
                                                             Max="252"/>
                                        </MudItem>
                                        <MudItem xs="4">
                                            <MudNumericField T="@(int?)"
                                                             Label="SpD"
                                                             @bind-Value="@spdEvMin"
                                                             Min="0"
                                                             Max="252"/>
                                        </MudItem>
                                        <MudItem xs="4">
                                            <MudNumericField T="@(int?)"
                                                             Label="Spe"
                                                             @bind-Value="@speEvMin"
                                                             Min="0"
                                                             Max="252"/>
                                        </MudItem>
                                    </MudGrid>

                                </MudStack>
                            </MudExpansionPanel>

                            @* ── Trainer ── *@
                            <MudExpansionPanel Text="Trainer">
                                <MudStack Spacing="2">

                                    <MudTextField @bind-Value="@otName"
                                                  Label="OT name (contains)"
                                                  Clearable/>

                                    <MudGrid Spacing="2">
                                        <MudItem xs="6">
                                            <MudNumericField T="@(uint?)"
                                                             Label="TID"
                                                             @bind-Value="@trainerId"
                                                             Min="0"/>
                                        </MudItem>
                                        <MudItem xs="6">
                                            <MudSelect T="@(int?)"
                                                       Label="Language"
                                                       @bind-Value="@languageId"
                                                       Clearable>
                                                <MudSelectItem T="@(int?)"
                                                               Value="@((int?)null)">Any
                                                </MudSelectItem>
                                                @foreach (var lang in GameInfo.LanguageDataSource(
                                                                  AppState.SaveFile?.Generation ?? 3,
                                                                  AppState.SaveFile?.Context ?? EntityContext.Gen3))
                                                {
                                                    <MudSelectItem T="@(int?)"
                                                                   Value="@lang.Value">@lang.Text</MudSelectItem>
                                                }
                                            </MudSelect>
                                        </MudItem>
                                    </MudGrid>

                                    <MudSelect T="@(int?)"
                                               Label="Origin game"
                                               @bind-Value="@originGame"
                                               Clearable>
                                        <MudSelectItem T="@(int?)"
                                                       Value="@((int?)null)">Any
                                        </MudSelectItem>
                                        @foreach (var game in GameInfo.FilteredSources.Games.Where(g => g.Value > 0))
                                        {
                                            <MudSelectItem T="@(int?)"
                                                           Value="@((int?)game.Value)">@game.Text</MudSelectItem>
                                        }
                                    </MudSelect>

                                </MudStack>
                            </MudExpansionPanel>

                            @* ── Moves ── *@
                            <MudExpansionPanel Text="Moves">
                                <MudStack Spacing="2">

                                    @* Any-of moves *@
                                    <MudText Typo="@Typo.subtitle2">Has any of these moves</MudText>
                                    <MudAutocomplete T="@ComboItem"
                                                     @ref="@anyMoveAutoRef"
                                                     Label="Add move…"
                                                     SearchFunc="@SearchMovesAsync"
                                                     ToStringFunc="@(m => m?.Text ?? string.Empty)"
                                                     ValueChanged="@AddAnyMove"
                                                     ResetValueOnEmptyText
                                                     Clearable/>
                                    <MudStack Row
                                              Wrap="@Wrap.Wrap"
                                              Spacing="1">
                                        @foreach (var move in anyMoveItems)
                                        {
                                            <MudChip T="@string"
                                                     Color="@Color.Primary"
                                                     Size="@Size.Small"
                                                     OnClose="@(() => RemoveAnyMove(move))">
                                                @move.Text
                                            </MudChip>
                                        }
                                    </MudStack>

                                    @* All-of moves *@
                                    <MudText Typo="@Typo.subtitle2">Has all of these moves</MudText>
                                    <MudAutocomplete T="@ComboItem"
                                                     @ref="@allMoveAutoRef"
                                                     Label="Add move…"
                                                     SearchFunc="@SearchMovesAsync"
                                                     ToStringFunc="@(m => m?.Text ?? string.Empty)"
                                                     ValueChanged="@AddAllMove"
                                                     ResetValueOnEmptyText
                                                     Clearable/>
                                    <MudStack Row
                                              Wrap="@Wrap.Wrap"
                                              Spacing="1">
                                        @foreach (var move in allMoveItems)
                                        {
                                            <MudChip T="@string"
                                                     Color="@Color.Secondary"
                                                     Size="@Size.Small"
                                                     OnClose="@(() => RemoveAllMove(move))">
                                                @move.Text
                                            </MudChip>
                                        }
                                    </MudStack>

                                </MudStack>
                            </MudExpansionPanel>

                            @* ── Misc ── *@
                            <MudExpansionPanel Text="Misc">
                                <MudStack Spacing="2">

                                    <MudStack Row
                                              AlignItems="@AlignItems.Center"
                                              Spacing="1">
                                        <MudSelect T="@(int?)"
                                                   Label="Ball"
                                                   Value="@ball"
                                                   ValueChanged="@OnBallFilterChanged"
                                                   Clearable
                                                   Style="flex:1;">
                                            <MudSelectItem T="@(int?)"
                                                           Value="@((int?)null)">Any
                                            </MudSelectItem>
                                            @foreach (var b in GameInfo.FilteredSources.Balls)
                                            {
                                                <MudSelectItem T="@(int?)"
                                                               Value="@b.Value">@b.Text</MudSelectItem>
                                            }
                                        </MudSelect>
                                        @if (ball is > 0)
                                        {
                                            <InfoButton>
                                                @if (filterBallInfo is { } ballInfo)
                                                {
                                                    <MudText Typo="@Typo.subtitle2">@ballInfo.Name</MudText>
                                                    <MudText Typo="@Typo.body2">@(string.IsNullOrEmpty(ballInfo.Description)
                                                            ? "No description available."
                                                            : ballInfo.Description)</MudText>
                                                }
                                                else
                                                {
                                                    <MudText Typo="@Typo.caption">Loading...</MudText>
                                                }
                                            </InfoButton>
                                        }
                                    </MudStack>

                                    <MudStack Row
                                              AlignItems="@AlignItems.Center"
                                              Spacing="1">
                                        <MudAutocomplete T="@ComboItem"
                                                         Label="Ability"
                                                         Value="@abilityItem"
                                                         ValueChanged="@OnAbilitySelected"
                                                         SearchFunc="@SearchAbilitiesAsync"
                                                         ToStringFunc="@ItemToString"
                                                         Clearable
                                                         ResetValueOnEmptyText
                                                         Style="flex:1;"/>
                                        @if (abilityId is > 0)
                                        {
                                            <InfoButton>
                                                @if (filterAbilityInfo is { } abilityInfo)
                                                {
                                                    <MudText Typo="@Typo.subtitle2">@abilityInfo.Name</MudText>
                                                    <MudText Typo="@Typo.body2">@(string.IsNullOrEmpty(abilityInfo.Description)
                                                            ? "No description available."
                                                            : abilityInfo.Description)</MudText>
                                                }
                                                else
                                                {
                                                    <MudText Typo="@Typo.caption">Loading...</MudText>
                                                }
                                            </InfoButton>
                                        }
                                    </MudStack>

                                    <MudStack Row
                                              AlignItems="@AlignItems.Center"
                                              Spacing="1">
                                        <MudAutocomplete T="@ComboItem"
                                                         Label="Held item"
                                                         SearchFunc="@SearchItemsAsync"
                                                         ToStringFunc="@ItemToString"
                                                         ValueChanged="@OnHeldItemFilterChanged"
                                                         Clearable
                                                         ResetValueOnEmptyText
                                                         Style="flex:1;"/>
                                        @if (heldItemId is > 0)
                                        {
                                            <InfoButton>
                                                @if (filterHeldItemInfo is { } heldItemInfo)
                                                {
                                                    <MudText Typo="@Typo.subtitle2">@heldItemInfo.Name</MudText>
                                                    <MudText Typo="@Typo.body2">@(string.IsNullOrEmpty(heldItemInfo.Description)
                                                            ? "No description available."
                                                            : heldItemInfo.Description)</MudText>
                                                }
                                                else
                                                {
                                                    <MudText Typo="@Typo.caption">Loading...</MudText>
                                                }
                                            </InfoButton>
                                        }
                                    </MudStack>

                                    <MudSelect T="@(int?)"
                                               Label="Hidden Power type"
                                               @bind-Value="@hiddenPowerType"
                                               Clearable>
                                        <MudSelectItem T="@(int?)"
                                                       Value="@((int?)null)">Any
                                        </MudSelectItem>
                                        @for (var i = 0; i < HiddenPower.TypeCount; i++)
                                        {
                                            var typeIndex = i;
                                            <MudSelectItem T="@(int?)"
                                                           Value="@typeIndex">
                                                @GameInfo.Strings.Types[typeIndex + 1]
                                            </MudSelectItem>
                                        }
                                    </MudSelect>

                                </MudStack>
                            </MudExpansionPanel>

                            @* ── Origin ── *@
                            <MudExpansionPanel Text="Origin">
                                <MudStack Spacing="2">

                                    <MudAutocomplete T="@ComboItem"
                                                     Label="Met location"
                                                     Value="@metLocationItem"
                                                     ValueChanged="@(v => metLocationItem = v)"
                                                     SearchFunc="@SearchMetLocationsAsync"
                                                     ToStringFunc="@(l => l?.Text ?? string.Empty)"
                                                     Clearable
                                                     ResetValueOnEmptyText/>

                                    <MudGrid Spacing="2">
                                        <MudItem xs="6">
                                            <MudDatePicker Label="Met date (from)"
                                                           @bind-Date="@metDateMin"
                                                           Clearable/>
                                        </MudItem>
                                        <MudItem xs="6">
                                            <MudDatePicker Label="Met date (to)"
                                                           @bind-Date="@metDateMax"
                                                           Clearable/>
                                        </MudItem>
                                    </MudGrid>

                                    <MudSelect T="@(int?)"
                                               Label="Pokerus"
                                               @bind-Value="@pokerusState"
                                               Clearable>
                                        <MudSelectItem T="@(int?)"
                                                       Value="@((int?)null)">Any
                                        </MudSelectItem>
                                        <MudSelectItem T="@(int?)"
                                                       Value="@((int?)0)">Never infected
                                        </MudSelectItem>
                                        <MudSelectItem T="@(int?)"
                                                       Value="@((int?)1)">Currently infected
                                        </MudSelectItem>
                                        <MudSelectItem T="@(int?)"
                                                       Value="@((int?)2)">Cured
                                        </MudSelectItem>
                                    </MudSelect>

                                </MudStack>
                            </MudExpansionPanel>

                            @* ── Ribbons / Marks ── *@
                            <MudExpansionPanel Text="Ribbons / Marks">
                                <MudStack Spacing="2">

                                    @{
                                        var markingShapes = GetAvailableMarkingShapes().ToList();
                                    }
                                    @if (markingShapes.Count > 0)
                                    {
                                        <MudText Typo="@Typo.subtitle2">Markings</MudText>
                                        <MudStack Row
                                                  Wrap="@Wrap.Wrap"
                                                  Spacing="1">
                                            @foreach (var (markingIndex, symbol, label) in markingShapes)
                                            {
                                                var idx = markingIndex;
                                                var isSelected = selectedMarkings.Contains(idx);
                                                <MudChip T="@int"
                                                         Value="@idx"
                                                         Variant="@(isSelected ? Variant.Filled : Variant.Outlined)"
                                                         Color="@(isSelected ? Color.Primary : Color.Default)"
                                                         Size="@Size.Large"
                                                         OnClick="@(() => ToggleMarking(idx))"
                                                         title="@label">
                                                    @symbol
                                                </MudChip>
                                            }
                                        </MudStack>
                                    }

                                    <MudText Typo="@Typo.subtitle2">Ribbons</MudText>
                                    <MudAutocomplete T="@string"
                                                     Label="Add ribbon…"
                                                     Value="@pendingRibbonName"
                                                     ValueChanged="@AddRibbon"
                                                     SearchFunc="@SearchRibbonNamesAsync"
                                                     ToStringFunc="@(n => string.IsNullOrEmpty(n) ? string.Empty : RibbonHelper.GetRibbonDisplayName(n))"
                                                     ResetValueOnEmptyText
                                                     Clearable/>

                                    <MudStack Row
                                              Wrap="@Wrap.Wrap"
                                              Spacing="1">
                                        @foreach (var ribbon in selectedRibbons)
                                        {
                                            var ribbonName = ribbon;
                                            <MudChip T="@string"
                                                     Color="@Color.Warning"
                                                     Size="@Size.Small"
                                                     OnClose="@(() => RemoveRibbon(ribbonName))">
                                                @RibbonHelper.GetRibbonDisplayName(ribbonName)
                                            </MudChip>
                                        }
                                    </MudStack>

                                </MudStack>
                            </MudExpansionPanel>

                        </MudExpansionPanels>

                    </div>

                    @* Action buttons *@
                    <MudStack Row
                              Spacing="2"
                              Class="search-filter-panel-actions">
                        <MudButton Variant="@Variant.Filled"
                                   Color="@Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Search"
                                   OnClick="@RunSearchAsync"
                                   Disabled="@isSearching">
                            @(isSearching
                                ? "Searching…"
                                : "Search")
                        </MudButton>

                        @if (isSearching)
                        {
                            <MudProgressCircular Indeterminate
                                                 Size="@Size.Small"
                                                 Color="@Color.Primary"/>
                        }

                        <MudButton Variant="@Variant.Outlined"
                                   StartIcon="@Icons.Material.Filled.Clear"
                                   OnClick="@ResetFilter"
                                   Disabled="@isSearching">
                            Reset
                        </MudButton>
                    </MudStack>

                </MudStack>
            </MudItem>

            @* ── Results panel ── *@
            <MudItem xs="12"
                     md="7">
                <MudStack Spacing="2">

                    @if (HasResults)
                    {
                        <MudChip T="@string"
                                 Color="@Color.Default"
                                 Variant="@Variant.Outlined"
                                 Size="@Size.Small">
                            @ResultCount result@(ResultCount == 1
                                                       ? string.Empty
                                                       : "s") found
                        </MudChip>
                    }

                    @* Batch operations *@
                    @if (HasSelection)
                    {
                        <MudStack Row
                                  Spacing="2"
                                  AlignItems="@AlignItems.Center"
                                  Wrap="@Wrap.Wrap">
                            <MudText Typo="@Typo.body2">@selectedRows.Count selected</MudText>
                            <MudButton Size="@Size.Small"
                                       Variant="@Variant.Outlined"
                                       StartIcon="@Icons.Material.Filled.ContentCopy"
                                       OnClick="@CopyShowdownAsync">
                                Copy Showdown text
                            </MudButton>
                        </MudStack>
                    }

                    <MudTable T="@AdvancedSearchResult"
                              Items="@results"
                              Dense
                              Hover
                              Bordered
                              MultiSelection
                              FixedHeader
                              Height="calc(100dvh - 280px)"
                              @bind-SelectedItems="@selectedRows"
                              SortLabel="Sort By"
                              RowsPerPage="25">

                        <HeaderContent>

                            <MudTh>
                                <MudTableSortLabel
                                    SortBy="@(new Func<AdvancedSearchResult, object>(r => r.SpeciesName))">
                                    Species
                                </MudTableSortLabel>
                            </MudTh>

                            <MudTh>
                                <MudTableSortLabel
                                    SortBy="@(new Func<AdvancedSearchResult, object>(r => r.Location))">
                                    Location
                                </MudTableSortLabel>
                            </MudTh>

                            <MudTh>
                                <MudTableSortLabel
                                    SortBy="@(new Func<AdvancedSearchResult, object>(r => (int)r.Pokemon.CurrentLevel))">
                                    Lv
                                </MudTableSortLabel>
                            </MudTh>

                            <MudTh>Shiny</MudTh>

                            <MudTh>
                                <MudTableSortLabel
                                    SortBy="@(new Func<AdvancedSearchResult, object>(r => (int)r.Pokemon.Nature))">
                                    Nature
                                </MudTableSortLabel>
                            </MudTh>

                            <MudTh>
                                <MudTableSortLabel
                                    SortBy="@(new Func<AdvancedSearchResult, object>(r => r.Pokemon.Ability))">
                                    Ability
                                </MudTableSortLabel>
                            </MudTh>

                            <MudTh>Ball</MudTh>

                            <MudTh>Held Item</MudTh>

                            <MudTh></MudTh>

                        </HeaderContent>

                        <RowTemplate>

                            <MudTd DataLabel="Species">@context.SpeciesName</MudTd>

                            <MudTd DataLabel="Location">@context.Location</MudTd>

                            <MudTd DataLabel="Lv">@context.Pokemon.CurrentLevel</MudTd>

                            <MudTd DataLabel="Shiny">
                                @if (context.Pokemon.IsShiny)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Star"
                                             Color="@Color.Warning"
                                             Size="@Size.Small"/>
                                }
                            </MudTd>

                            <MudTd DataLabel="Nature">
                                @(GameInfo.FilteredSources.Natures
                                    .FirstOrDefault(n => n.Value == (int)context.Pokemon.Nature)?.Text
                                ?? context.Pokemon.Nature.ToString())
                            </MudTd>

                            <MudTd DataLabel="Ability">
                                    <span @onclick:stopPropagation="true"
                                          style="display:inline-flex;align-items:center;gap:4px;">
                                        @(GameInfo.FilteredSources.Abilities
                                            .FirstOrDefault(a => a.Value == context.Pokemon.Ability)?.Text
                                        ?? context.Pokemon.Ability.ToString())
                                        <InfoButton>
                                            @if (loadedAbilities.TryGetValue(context.Pokemon.Ability, out var abilityInfo)
                                                 && abilityInfo is not null)
                                            {
                                                <MudText Typo="@Typo.subtitle2">@abilityInfo.Name</MudText>
                                                <MudText Typo="@Typo.body2">@(string.IsNullOrEmpty(abilityInfo.Description)
                                                        ? "No description available."
                                                        : abilityInfo.Description)</MudText>
                                            }
                                            else
                                            {
                                                <MudText Typo="@Typo.caption">Loading...</MudText>
                                            }
                                        </InfoButton>
                                    </span>
                            </MudTd>

                            <MudTd DataLabel="Ball">
                                @{
                                    var ballName = GameInfo.FilteredSources.Balls
                                        .FirstOrDefault(b => b.Value == context.Pokemon.Ball)?.Text;
                                }
                                <span @onclick:stopPropagation="true"
                                      style="display:inline-flex;align-items:center;gap:4px;">
                                        <img src="@ImageHelper.GetBallSpriteFilename(context.Pokemon.Ball)"
                                             style="width:20px;height:20px;object-fit:contain;"
                                             title="@(ballName ?? "Ball")"
                                             alt="@(ballName ?? "Ball")"/>
                                        <InfoButton>
                                            @if (loadedBalls.TryGetValue(context.Pokemon.Ball, out var ballInfo))
                                            {
                                                @if (ballInfo is not null)
                                                {
                                                    <MudText Typo="@Typo.subtitle2">@ballInfo.Name</MudText>
                                                    <MudText Typo="@Typo.body2">@(string.IsNullOrEmpty(ballInfo.Description)
                                                            ? "No description available."
                                                            : ballInfo.Description)</MudText>
                                                }
                                                else
                                                {
                                                    <MudText Typo="@Typo.body2">@(ballName ?? "Unknown ball")</MudText>
                                                    <MudText Typo="@Typo.caption">No description available.</MudText>
                                                }
                                            }
                                            else
                                            {
                                                <MudText Typo="@Typo.caption">Loading...</MudText>
                                            }
                                        </InfoButton>
                                    </span>
                            </MudTd>

                            <MudTd DataLabel="Held Item">
                                @if (context.Pokemon.HeldItem > 0
                                     && AppState.SaveFile is { } sf
                                     && context.Pokemon.HeldItem < GameInfo.Strings.itemlist.Length)
                                {
                                    var heldItemName = GameInfo.Strings.itemlist[context.Pokemon.HeldItem];
                                    <span @onclick:stopPropagation="true"
                                          style="display:inline-flex;align-items:center;gap:4px;">
                                            <object class="item-sprite"
                                                    type="image/png"
                                                    style="object-fit:contain;width:24px;height:24px;"
                                                    data="@ImageHelper.GetItemSpriteFilename(context.Pokemon.HeldItem, sf.Context)"
                                                    title="@heldItemName">
                                                <img src="@ImageHelper.ItemFallbackImageFileName"
                                                     style="width:24px;height:24px;"
                                                     title="@heldItemName"
                                                     alt="@heldItemName"/>
                                            </object>
                                            <InfoButton>
                                                @if (loadedHeldItems.TryGetValue(context.Pokemon.HeldItem, out var heldItemInfo))
                                                {
                                                    @if (heldItemInfo is not null)
                                                    {
                                                        <MudText Typo="@Typo.subtitle2">@heldItemInfo.Name</MudText>
                                                        <MudText Typo="@Typo.body2">@(string.IsNullOrEmpty(heldItemInfo.Description)
                                                                ? "No description available."
                                                                : heldItemInfo.Description)</MudText>
                                                    }
                                                    else
                                                    {
                                                        <MudText Typo="@Typo.body2">@heldItemName</MudText>
                                                        <MudText Typo="@Typo.caption">No description available.</MudText>
                                                    }
                                                }
                                                else
                                                {
                                                    <MudText Typo="@Typo.caption">Loading...</MudText>
                                                }
                                            </InfoButton>
                                        </span>
                                }
                            </MudTd>

                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                               Size="@Size.Small"
                                               Color="@Color.Primary"
                                               title="Jump to Pokémon"
                                               OnClick="@(() => JumpToResultAsync(context))"/>
                            </MudTd>

                        </RowTemplate>

                        <NoRecordsContent>
                            @if (isSearching)
                            {
                                <MudText>Searching…</MudText>
                            }
                            else if (!hasSearched)
                            {
                                <MudText>Run a search to see results here.</MudText>
                            }
                            else
                            {
                                <MudText>No Pokémon match the current filter.</MudText>
                            }
                        </NoRecordsContent>

                        <PagerContent>
                            <MudTablePager/>
                        </PagerContent>

                    </MudTable>

                </MudStack>
            </MudItem>

        </MudGrid>
    }

</MudStack>
