@inherits RefreshAwareComponent

<MudGrid Spacing="1"
         Justify="@Justify.FlexStart"
         Class="party-box-grid">
    <MudItem xs="12"
             lg="6"
             Style="max-width: 480px;">
        <MudPaper Elevation="0">
            <PokemonStorageComponent/>
        </MudPaper>
    </MudItem>
    <MudItem xs="12"
             lg="6"
             Class="edit-form-column">
        <MudPaper Elevation="0">
            @if (AppState.PinnedBoxNumber is not null)
            {
                <PinnedBoxComponent/>
            }
            else
            {
                <PokemonEditForm Pokemon="@AppService.EditFormPokemon"/>
            }
        </MudPaper>
    </MudItem>
</MudGrid>
