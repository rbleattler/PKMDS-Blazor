@code {
    protected const string ColumnClass = "d-flex align-center justify-center";

    private static string GetTypeName(byte type) =>
        type < GameInfo.Strings.Types.Count ? GameInfo.Strings.Types[type] : "???";

    private static RenderFragment TypeSummary(byte type1, byte type2) =>
        @<MudStack Row
                   Class="my-2"
                   AlignItems="@AlignItems.Center">
            <MudText>
                Type:
            </MudText>
            <MudImage Src="@ImageHelper.GetTypeWideSpriteFileName(type1)"
                      Alt="@GetTypeName(type1)"
                      title="@GetTypeName(type1)"
                      ObjectFit="@ObjectFit.Contain"
                      ObjectPosition="@ObjectPosition.Center"/>
            @if (type1 != type2)
            {
                <MudImage Src="@ImageHelper.GetTypeWideSpriteFileName(type2)"
                          Alt="@GetTypeName(type2)"
                          title="@GetTypeName(type2)"
                          ObjectFit="@ObjectFit.Contain"
                          ObjectPosition="@ObjectPosition.Center"/>
            }
        </MudStack>;

    protected static RenderFragment TypeSummary((byte Type1, byte Type2) types) =>
        TypeSummary(types.Type1, types.Type2);

    protected static RenderFragment MoveTypeSummary(byte type) =>
        @<MudImage Src="@ImageHelper.GetTypeSquareSpriteFileName(type)"
                   Alt="@GetTypeName(type)"
                   title="@GetTypeName(type)"
                   ObjectFit="@ObjectFit.Contain"
                   ObjectPosition="@ObjectPosition.Center"
                   Width="30"/>;

    protected static RenderFragment MoveCategorySummary(MoveCategory moveCategory) =>
        @<MudImage Src="@ImageHelper.GetMoveCategorySpriteFileName(moveCategory)"
                   Alt="@GetCategoryName(moveCategory)"
                   title="@GetCategoryName(moveCategory)"
                   ObjectFit="@ObjectFit.Contain"
                   ObjectPosition="@ObjectPosition.Center"
                   Width="30"/>;

    protected static RenderFragment MoveTypeAndCategorySummary(byte type, MoveCategory category) =>
        @<MudStack Row
                   AlignItems="@AlignItems.Center"
                   Spacing="0">
            @MoveTypeSummary(type)
            @MoveCategorySummary(category)
        </MudStack>;

}
