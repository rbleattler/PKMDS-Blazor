@inherits BasePkmdsComponent

@if (Pokemon is not null &&
     AppState is
     {
         SaveFile:
         {
             Context: not
             (EntityContext.None or
             EntityContext.SplitInvalid or
             EntityContext.MaxInvalid),
             Generation: var saveGeneration
         },
         SelectedSlotsAreValid: true
     })
{
    <MudStack Class="mt-2"
              Spacing="2">

        @* Gen 1 — Catch Rate *@
        @if (Pokemon is PK1 pk1)
        {
            <MudText Typo="@Typo.subtitle2">Gen 1</MudText>

            <MudNumericField T="@byte"
                             Label="Catch Rate"
                             Variant="@Variant.Outlined"
                             Min="@byte.MinValue"
                             Max="@byte.MaxValue"
                             @bind-Value="@pk1.CatchRate"
                             title="Catch rate. This byte also determines the held item when traded to Gen 2."/>
        }

        @* Gen 1/2 — Status Condition *@
        @if (saveGeneration <= 2)
        {
            @if (Pokemon is PK1)
            {
                @* Gen 1 section above already renders the "Gen 1" heading — no duplicate heading needed here *@
            }
            else
            {
                <MudText Typo="@Typo.subtitle2">Gen 2</MudText>
            }

            <AutocompleteSelect T="@StatusCondition"
                                Label="Status Condition"
                                Value="@((StatusCondition)Pokemon.Status_Condition)"
                                ValueChanged="@(sc => Pokemon.Status_Condition = (int)sc)"
                                Items="@StatusConditionValues"
                                ToStringFunc="@GetStatusConditionText"/>
        }

        @* Gen 3 — Shadow (Colosseum / XD) *@
        @if (Pokemon is IShadowCapture shadow)
        {
            <MudDivider/>
            <MudText Typo="@Typo.subtitle2">Shadow Pokémon (Colo/XD)</MudText>

            <MudCheckBox Label="Is Shadow"
                         Value="@shadow.IsShadow"
                         ReadOnly/>

            <MudNumericField T="@ushort"
                             Label="Shadow ID"
                             Variant="@Variant.Outlined"
                             Min="@((ushort)0)"
                             Max="@ushort.MaxValue"
                             Value="@shadow.ShadowID"
                             ValueChanged="@(v => shadow.ShadowID = v)"
                             title="Shadow Pokémon slot ID"/>

            <MudNumericField T="@int"
                             Label="Purification"
                             Variant="@Variant.Outlined"
                             Min="@int.MinValue"
                             Max="@int.MaxValue"
                             Value="@shadow.Purification"
                             ValueChanged="@(v => shadow.Purification = v)"
                             title="Purification counter (counts down toward 0 for full purification)"/>
        }

        @* Gen 4 — ShinyLeaf + WalkingMood *@
        @if (Pokemon is G4PKM g4)
        {
            <MudDivider/>
            <MudText Typo="@Typo.subtitle2">Gen 4</MudText>

            <MudText Typo="@Typo.body2">Shiny Leaves</MudText>
            <MudStack Row
                      Wrap="@Wrap.Wrap">
                @for (var i = 0; i < 5; i++)
                {
                    var bit = i;
                    <HapticCheckBox T="@bool"
                                    Label="@($"Leaf {bit + 1}")"
                                    Value="@GetShinyLeafBit(g4.ShinyLeaf, bit)"
                                    ValueChanged="@(v => g4.ShinyLeaf = SetShinyLeafBit(g4.ShinyLeaf, bit, v))"
                                    title="@($"Shiny Leaf {bit + 1}")"/>
                }
                <HapticCheckBox T="@bool"
                                Label="Crown"
                                Value="@GetShinyLeafBit(g4.ShinyLeaf, 5)"
                                ValueChanged="@(v => g4.ShinyLeaf = SetShinyLeafBit(g4.ShinyLeaf, 5, v))"
                                title="Shiny Leaf Crown (requires all 5 leaves)"/>
            </MudStack>

            <MudNumericField T="@sbyte"
                             Label="Walking Mood"
                             Variant="@Variant.Outlined"
                             Min="@sbyte.MinValue"
                             Max="@sbyte.MaxValue"
                             Value="@g4.WalkingMood"
                             ValueChanged="@(v => g4.WalkingMood = v)"
                             title="Walking partner mood value (HG/SS)"/>
        }

        @* Gen 5 — N's Sparkle + PokéStar Fame *@
        @if (Pokemon is PK5 pk5)
        {
            <MudDivider/>
            <MudText Typo="@Typo.subtitle2">Gen 5</MudText>

            <HapticCheckBox T="@bool"
                            Label="N's Sparkle"
                            @bind-Value="@pk5.NSparkle"
                            @bind-Value:after="@RefreshService.Refresh"
                            For="@(() => pk5.NSparkle)"/>

            <MudNumericField T="@byte"
                             Label="PokéStar Fame (B2/W2 only)"
                             Variant="@Variant.Outlined"
                             Min="@byte.MinValue"
                             Max="@byte.MaxValue"
                             Value="@pk5.PokeStarFame"
                             ValueChanged="@(v => pk5.PokeStarFame = v)"
                             title="PokéStar Studios fame value (Black 2 / White 2 only; >250 = is a PokéStar)"/>
        }

        @* Gen 7b (LGPE) — Spirit, Mood, Received Date/Time *@
        @if (Pokemon is PB7 pb7)
        {
            <MudDivider/>
            <MudText Typo="@Typo.subtitle2">Let's Go (LGPE)</MudText>

            <MudNumericField T="@byte"
                             Label="Spirit"
                             Variant="@Variant.Outlined"
                             Min="@byte.MinValue"
                             Max="@byte.MaxValue"
                             Value="@pb7.Spirit"
                             ValueChanged="@(v => pb7.Spirit = v)"
                             title="GO Park spirit value"/>

            <MudNumericField T="@byte"
                             Label="Mood"
                             Variant="@Variant.Outlined"
                             Min="@byte.MinValue"
                             Max="@byte.MaxValue"
                             Value="@pb7.Mood"
                             ValueChanged="@(v => pb7.Mood = v)"
                             title="Partner Pokémon mood"/>

            <label for="pb7-received-date">Received Date (GO Park)</label>
            <InputDate Type="@InputDateType.Date"
                       id="pb7-received-date"
                       @bind-Value="@pb7.ReceivedDate"/>

            <MudText Typo="@Typo.body2">Received Time (GO Park)</MudText>
            <MudStack Row
                      Spacing="1">
                <MudNumericField T="@byte"
                                 Label="Hour"
                                 Variant="@Variant.Outlined"
                                 Min="@((byte)0)"
                                 Max="@((byte)23)"
                                 Value="@pb7.ReceivedHour"
                                 ValueChanged="@(v => pb7.ReceivedHour = v)"/>
                <MudNumericField T="@byte"
                                 Label="Minute"
                                 Variant="@Variant.Outlined"
                                 Min="@((byte)0)"
                                 Max="@((byte)59)"
                                 Value="@pb7.ReceivedMinute"
                                 ValueChanged="@(v => pb7.ReceivedMinute = v)"/>
                <MudNumericField T="@byte"
                                 Label="Second"
                                 Variant="@Variant.Outlined"
                                 Min="@((byte)0)"
                                 Max="@((byte)59)"
                                 Value="@pb7.ReceivedSecond"
                                 ValueChanged="@(v => pb7.ReceivedSecond = v)"/>
            </MudStack>
        }

        @* Gen 8 (SwSh) — Dynamax Level + Gigantamax *@
        @if (Pokemon is IDynamaxLevel dynLevel && dynLevel.CanHaveDynamaxLevel(Pokemon))
        {
            <MudDivider/>
            <MudText Typo="@Typo.subtitle2">Gen 8 (Sword/Shield)</MudText>

            <MudStack Row
                      Wrap="@Wrap.Wrap"
                      AlignItems="@AlignItems.Center">
                <MudNumericField T="@byte"
                                 Label="Dynamax Level"
                                 Variant="@Variant.Outlined"
                                 Min="@byte.MinValue"
                                 Max="@Constants.MaxDynamaxLevel"
                                 @bind-Value="@dynLevel.DynamaxLevel"
                                 Style="max-width: 160px;"/>
                @if (Pokemon is IGigantamax gigantamax)
                {
                    <HapticCheckBox T="@bool"
                                    Label="Gigantamax"
                                    @bind-Value="@gigantamax.CanGigantamax"
                                    For="@(() => gigantamax.CanGigantamax)"/>
                }
            </MudStack>
        }

        @* Gen 8 (PLA) — Noble + Alpha *@
        @if (Pokemon is INoble or IAlphaReadOnly)
        {
            <MudDivider/>
            <MudText Typo="@Typo.subtitle2">Gen 8 (Legends: Arceus)</MudText>

            <MudStack Row
                      Wrap="@Wrap.Wrap">
                @if (Pokemon is INoble noble)
                {
                    <HapticCheckBox T="@bool"
                                    Label="Noble"
                                    @bind-Value="@noble.IsNoble"
                                    For="@(() => noble.IsNoble)"/>
                }
                @switch (Pokemon)
                {
                    case IAlpha alpha:
                        <HapticCheckBox T="@bool"
                                        Label="Alpha"
                                        @bind-Value="@alpha.IsAlpha"
                                        For="@(() => alpha.IsAlpha)"/>
                        break;
                    case IAlphaReadOnly alphaReadOnly:
                        <MudCheckBox Label="Alpha"
                                     Value="@alphaReadOnly.IsAlpha"
                                     ReadOnly/>
                        break;
                }
            </MudStack>
        }

        @* Gen 9 — Tera Type *@
        @if (Pokemon is ITeraType tt)
        {
            <MudDivider/>
            <MudText Typo="@Typo.subtitle2">Gen 9 (Scarlet/Violet)</MudText>

            <MudGrid>
                <MudItem xs="9">
                    <MudStack>
                        <MudStack Row
                                  AlignItems="@AlignItems.Center"
                                  Spacing="1">
                            <MudStack Style="flex: 1; min-width: 0;">
                                <AutocompleteSelect T="@MoveType"
                                                    Label="Original Tera Type"
                                                    @bind-Value="@tt.TeraTypeOriginal"
                                                    Items="@TeraTypeOriginalItems"
                                                    ToStringFunc="@GetTeraTypeText"
                                                    For="@(() => tt.TeraTypeOriginal)">
                                    <ItemTemplate Context="teraType">
                                        <MudStack Row
                                                  Class="my-2"
                                                  AlignItems="@AlignItems.Center">
                                            @RenderTeraTypeImage((byte)teraType)
                                            <MudText>
                                                @GetTeraTypeDisplayName((byte)teraType)
                                            </MudText>
                                        </MudStack>
                                    </ItemTemplate>
                                </AutocompleteSelect>
                            </MudStack>
                            @RenderTeraTypeImage((byte)tt.TeraTypeOriginal)
                        </MudStack>
                        <MudStack Row
                                  AlignItems="@AlignItems.Center"
                                  Spacing="1">
                            <MudStack Style="flex: 1; min-width: 0;">
                                <AutocompleteSelect T="@MoveType"
                                                    Label="Override Tera Type"
                                                    @bind-Value="@tt.TeraTypeOverride"
                                                    Items="@TeraTypeOverrideItems"
                                                    ToStringFunc="@GetTeraTypeText"
                                                    For="@(() => tt.TeraTypeOverride)">
                                    <ItemTemplate Context="teraType">
                                        @if ((byte)teraType == TeraTypeUtil.OverrideNone)
                                        {
                                            <MudText>@Constants.EmptyIndex</MudText>
                                        }
                                        else
                                        {
                                            <MudStack Row
                                                      Class="my-2"
                                                      AlignItems="@AlignItems.Center">
                                                @RenderTeraTypeImage((byte)teraType)
                                                <MudText>
                                                    @GetTeraTypeDisplayName((byte)teraType)
                                                </MudText>
                                            </MudStack>
                                        }
                                    </ItemTemplate>
                                </AutocompleteSelect>
                            </MudStack>
                            @if ((byte)tt.TeraTypeOverride != TeraTypeUtil.OverrideNone)
                            {
                                @RenderTeraTypeImage((byte)tt.TeraTypeOverride)
                            }
                            else
                            {
                                <span style="width: 30px;"></span>
                            }
                        </MudStack>
                    </MudStack>
                </MudItem>
                <MudItem xs="3"
                         Style="align-self: center;">
                    <MudStack>
                        <MudText Align="@Align.Center">
                            Current Tera Type: @GetTeraTypeDisplayName((byte)tt.TeraType)
                        </MudText>
                        <div class="current-tera-type-image">
                            @RenderTeraTypeImage((byte)tt.TeraType, 60)
                        </div>
                    </MudStack>
                </MudItem>
            </MudGrid>
        }

    </MudStack>
}

@code {

    private RenderFragment RenderTeraTypeImage(byte teraTypeId, int width = 30) =>
        @<MudImage Src="@ImageHelper.GetTypeGemSpriteFileName(teraTypeId)"
                   Alt="@GetTeraTypeDisplayName(teraTypeId)"
                   title="@GetTeraTypeDisplayName(teraTypeId)"
                   ObjectFit="@ObjectFit.Contain"
                   ObjectPosition="@ObjectPosition.Center"
                   Width="@width"/>;

}
