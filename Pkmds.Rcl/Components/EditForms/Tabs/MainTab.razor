@inherits BasePkmdsComponent

@if (Pokemon is not null &&
     AppState is
     {
         SaveFile:
         {
             Context: not
             (EntityContext.None or
             EntityContext.SplitInvalid or
             EntityContext.MaxInvalid),
             Generation: var saveGeneration
         } saveFile,
         SelectedSlotsAreValid: true
     })
{
    @if (saveGeneration >= 3)
    {
        <MudStack Row
                  AlignItems="@AlignItems.Center"
                  Spacing="1">
            <MudStack Style="flex: 1; min-width: 0;">
                <MudNumericField Label="PID"
                                 Variant="@Variant.Outlined"
                                 Min="0U"
                                 Max="@uint.MaxValue"
                                 @bind-Value:get="@Pokemon.PID"
                                 @bind-Value:set="@(newPid => SetPokemonPid(newPid))"
                                 For="@(() => Pokemon.PID)"/>
            </MudStack>
            <LegalityIndicator Severity="@(GetCheckResult(CheckIdentifier.PID)?.Judgement ?? PKHeX.Core.Severity.Valid)"
                               Message="@HumanizeCheckResult(GetCheckResult(CheckIdentifier.PID))"/>
        </MudStack>

        <MudTextField Label="PID (Hex)"
                      Variant="@Variant.Outlined"
                      MaxLength="8"
                      Mask="@Constants.HexMask"
                      @bind-Value:get="@Pokemon.PID.ToString("X8")"
                      @bind-Value:set="@((string newPidHex) => SetPokemonPid(newPidHex))"/>

        <MudButton OnClick="@OpenPidEcDialog"
                   Variant="@Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.AutoFixHigh"
                   Class="mb-2">
            Generate PID / EC...
        </MudButton>

        @if (IsSpinda)
        {
            <MudButton OnClick="@OpenSpindaPatternDialog"
                       Variant="@Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.Pets"
                       Class="mb-2">
                View Spot Pattern...
            </MudButton>
        }
    }

    @* ReSharper disable once CSharpWarnings::CS8603 *@
    <MudAutocomplete T="@ComboItem"
                     Label="Species"
                     Variant="@Variant.Outlined"
                     @bind-Value:get="@(AppService.GetSpeciesComboItem(Pokemon.Species))"
                     @bind-Value:set="@(species => SetSpecies((ushort)species.Value))"
                     SearchFunc="@SearchPokemonNames"
                     ToStringFunc="@(species => species?.Text)"/>

    if (Pokemon != saveFile.BlankPKM && Pokemon.Species.IsValidSpecies())
    {
        @TypeSummary(Pokemon.GetGenerationTypes())
    }

    @if (CanEvolve)
    {
        <MudButton OnClick="@EvolveAsync"
                   Variant="@Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.Upgrade"
                   Color="@Color.Primary"
                   Class="mb-2">
            Evolve...
        </MudButton>
    }

    <MudStack Row>

        <MudCheckBox Label="Is Nicknamed"
                     @bind-Value="@Pokemon.IsNicknamed"
                     For="@(() => Pokemon.IsNicknamed)"/>

        <MudButton OnClick="@RevertNickname"
                   ButtonType="@ButtonType.Button"
                   Variant="@Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Undo"
                   Color="@Color.Default"
                   Disabled="@(!Pokemon.IsNicknamed)">
            Revert Nickname
        </MudButton>

    </MudStack>

    <MudStack Row
              AlignItems="@AlignItems.Center"
              Spacing="1">
        <MudStack Style="flex: 1; min-width: 0;">
            <MudTextField Label="Nickname"
                          Variant="@Variant.Outlined"
                          Text="@Pokemon.Nickname"
                          TextChanged="@SetPokemonNickname"
                          MaxLength="@saveFile.MaxStringLengthNickname"
                          For="@(() => Pokemon.Nickname)"/>
        </MudStack>
        <LegalityIndicator
            Severity="@(GetCheckResult(CheckIdentifier.Nickname)?.Judgement ?? PKHeX.Core.Severity.Valid)"
            Message="@HumanizeCheckResult(GetCheckResult(CheckIdentifier.Nickname))"/>
        @if (Pokemon.NicknameTrash.Length > 0)
        {
            <MudTooltip Text="Edit trash bytes...">
                <MudIconButton Icon="@Icons.Material.Filled.EditNote"
                               Size="@Size.Small"
                               OnClick="@(() => OpenTrashBytesEditor(StringSource.Nickname))"/>
            </MudTooltip>
        }
    </MudStack>

    @if (saveGeneration >= 2)
    {
        <MudStack Row
                  AlignItems="@AlignItems.Center"
                  Spacing="1">
            <GenderDisplayComponent Gender="@((Gender)Pokemon.Gender)"
                                    OnChange="@OnGenderToggle"
                                    ReadOnly="@(!Pokemon.PersonalInfo.IsDualGender)"/>
            <LegalityIndicator
                Severity="@(GetCheckResult(CheckIdentifier.Gender)?.Judgement ?? PKHeX.Core.Severity.Valid)"
                Message="@HumanizeCheckResult(GetCheckResult(CheckIdentifier.Gender))"/>
        </MudStack>
    }

    <MudNumericField Label="Level"
                     Variant="@Variant.Outlined"
                     @bind-Value="@Pokemon.CurrentLevel"
                     @bind-Value:after="@(() => AppService.LoadPokemonStats(Pokemon))"
                     For="@(() => Pokemon.CurrentLevel)"/>

    <MudNumericField Label="EXP"
                     Variant="@Variant.Outlined"
                     @bind-Value="@Pokemon.EXP"
                     @bind-Value:after="@(() => AppService.LoadPokemonStats(Pokemon))"
                     For="@(() => Pokemon.EXP)"/>

    <MudNumericField Label="EXP to next level"
                     Variant="@Variant.Outlined"
                     Value="@GetEXPToLevelUp()"
                     ReadOnly
                     HideSpinButtons/>

    var levelProgress = Experience.GetEXPToLevelUpPercentage(Pokemon.CurrentLevel, Pokemon.EXP, Pokemon.PersonalInfo.EXPGrowth);
    <MudProgressLinear
        Value="@(levelProgress * 100)"
        Color="@Color.Primary"
        Size="@Size.Medium"
        Rounded
        Class="mt-2"
        title="@(levelProgress.ToString("P0"))"/>

    @if (saveGeneration >= 3)
    {
        <MudStack Row
                  AlignItems="@AlignItems.Center"
                  Spacing="1">
            <MudStack Style="flex: 1; min-width: 0;">
                <MudSelect Label="Nature"
                           Variant="@Variant.Outlined"
                           @bind-Value:get="@Pokemon.Nature"
                           @bind-Value:set="@OnNatureSet"
                           For="@(() => Pokemon.Nature)">
                    @foreach (var nature in GameInfo.FilteredSources.Natures.DistinctBy(nature => nature.Value))
                    {
                        <MudSelectItem Value="@((Nature)nature.Value)"
                                       @key="@nature.Value">
                            <MudStack Row>
                                <MudText>
                                    @nature.Text
                                </MudText>
                                <MudText>
                                    @AppService.GetStatModifierString((Nature)nature.Value)
                                </MudText>
                            </MudStack>
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudStack>
            <LegalityIndicator
                Severity="@(GetCheckResult(CheckIdentifier.Nature)?.Judgement ?? PKHeX.Core.Severity.Valid)"
                Message="@HumanizeCheckResult(GetCheckResult(CheckIdentifier.Nature))"/>
        </MudStack>
    }

    @if (saveGeneration >= 8)
    {
        <MudSelect Label="Stat Nature"
                   Variant="@Variant.Outlined"
                   @bind-Value:get="@Pokemon.StatNature"
                   @bind-Value:set="@OnStatNatureSet"
                   For="@(() => Pokemon.StatNature)">
            @foreach (var nature in GameInfo.FilteredSources.Natures.DistinctBy(nature => nature.Value))
            {
                <MudSelectItem Value="@((Nature)nature.Value)"
                               @key="@nature.Value">
                    <MudStack Row>
                        <MudText>
                            @nature.Text
                        </MudText>
                        <MudText>
                            @AppService.GetStatModifierString((Nature)nature.Value)
                        </MudText>
                    </MudStack>
                </MudSelectItem>
            }
        </MudSelect>
    }

    @if (FormInfo.HasFormSelection(saveFile.Personal[Pokemon.Species], Pokemon.Species, Pokemon.Format))
    {
        var forms = FormConverter.GetFormList(Pokemon.Species, GameInfo.Strings.types, GameInfo.Strings.forms, GameInfo.GenderSymbolUnicode, Pokemon.Context);
        if (forms.AsEnumerable().Any(f => !string.IsNullOrEmpty(f)))
        {
            <MudStack Row
                      AlignItems="@AlignItems.Center"
                      Spacing="1">
                <MudStack Style="flex: 1; min-width: 0;">
                    <MudSelect T="@byte"
                               @ref="@FormSelect"
                               Label="Form"
                               Variant="@Variant.Outlined"
                               @bind-Value="@Pokemon.Form"
                               @bind-Value:after="@AfterFormChanged"
                               For="@(() => Pokemon.Form)">
                        @for (byte i = 0; i < forms.Length; i++)
                        {
                            var formId = i;
                            <MudSelectItem Value="@formId"
                                           @key="@formId">
                                @forms[formId]
                            </MudSelectItem>
                        }
                    </MudSelect>
                </MudStack>
                <MudImage Src="@GetFormPreviewSprite()"
                          Alt="Form preview"
                          title="@forms.ElementAtOrDefault(Pokemon.Form)"
                          ObjectFit="@ObjectFit.Contain"
                          ObjectPosition="@ObjectPosition.Center"
                          Width="40"
                          Height="30"/>
                <LegalityIndicator
                    Severity="@(GetCheckResult(CheckIdentifier.Form)?.Judgement ?? PKHeX.Core.Severity.Valid)"
                    Message="@HumanizeCheckResult(GetCheckResult(CheckIdentifier.Form))"/>
            </MudStack>

            @if (Pokemon is IFormArgument && FormArgumentUtil.GetFormArgumentMax(Pokemon.Species, Pokemon.Form, Pokemon.Context) > 0 && FormConverter.GetFormArgumentIsNamedIndex(Pokemon.Species))
            {
                <MudSelect T="@(uint?)"
                           Label="Form Arg"
                           Variant="@Variant.Outlined"
                           @bind-Value:get="@(Pokemon.GetFormArgument())"
                           @bind-Value:set="@(formArg =>
                                            {
                                                Pokemon.ChangeFormArgument(formArg ?? 0);
                                                AppService.LoadPokemonStats(Pokemon);
                                                RefreshService.Refresh();
                                            })">
                    @{
                        var formArgs = FormConverter.GetFormArgumentStrings(Pokemon.Species);
                    }
                    @for (uint i = 0; i < formArgs.Length; i++)
                    {
                        var formArg = i;
                        <MudSelectItem Value="@formArg"
                                       @key="@formArg">
                            @formArgs[formArg]
                        </MudSelectItem>
                    }
                </MudSelect>
            }

            @if (IsAlcremie)
            {
                <MudButton OnClick="@OpenAlcremieEditorDialog"
                           Variant="@Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.Palette"
                           Class="mb-2">
                    Edit Appearance...
                </MudButton>
            }
            else if (IsVivillon)
            {
                <MudButton OnClick="@OpenVivillonEditorDialog"
                           Variant="@Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.Palette"
                           Class="mb-2">
                    Edit Pattern...
                </MudButton>
            }
            else if (IsFurfrou)
            {
                <MudButton OnClick="@OpenFurfrouEditorDialog"
                           Variant="@Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.ContentCut"
                           Class="mb-2">
                    Edit Trim...
                </MudButton>
            }
            else if (IsPumpkabooOrGourgeist)
            {
                <MudButton OnClick="@OpenPumpkabooSizeDialog"
                           Variant="@Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.Straighten"
                           Class="mb-2">
                    Edit Size...
                </MudButton>
            }
            else if (IsMinior)
            {
                <MudButton OnClick="@OpenMiniorColorDialog"
                           Variant="@Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.ColorLens"
                           Class="mb-2">
                    Edit Color...
                </MudButton>
            }
            else if (IsFlabebebFamily)
            {
                <MudButton OnClick="@OpenFlowerColorDialog"
                           Variant="@Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.LocalFlorist"
                           Class="mb-2">
                    Edit Flower Color...
                </MudButton>
            }
        }
    }

    @if (saveGeneration >= 2 && saveFile.HeldItems.Length > 0)
    {
        <MudStack Row
                  Spacing="1"
                  AlignItems="@AlignItems.Center">

            @* ReSharper disable once CSharpWarnings::CS8603 *@
            <MudAutocomplete T="@ComboItem"
                             Label="Held Item"
                             Variant="@Variant.Outlined"
                             Clearable
                             @bind-Value:get="@(AppService.GetItemComboItem(Pokemon.HeldItem))"
                             @bind-Value:set="@SetHeldItem"
                             SearchFunc="@SearchItemNames"
                             ToStringFunc="@(item => item?.Text)">
                <ItemTemplate Context="item">
                    <MudStack Row>
                        @if (item.Value != 0)
                        {
                            <MudImage Src="@ImageHelper.GetItemSpriteFilename(item.Value, Pokemon.Context)"
                                      Alt="@item.Text"
                                      title="@item.Text"
                                      ObjectFit="@ObjectFit.Contain"
                                      ObjectPosition="@ObjectPosition.Center"
                                      Width="22"
                                      Height="22"/>
                        }
                        <MudText>
                            @item.Text
                        </MudText>
                    </MudStack>
                </ItemTemplate>
            </MudAutocomplete>

            @if (Pokemon.HeldItem != 0)
            {
                var itemText = AppService.GetItemComboItem(Pokemon.HeldItem).Text;
                <MudImage Src="@ImageHelper.GetItemSpriteFilename(Pokemon.HeldItem, Pokemon.Context)"
                          Alt="@itemText"
                          title="@itemText"
                          ObjectFit="@ObjectFit.Contain"
                          ObjectPosition="@ObjectPosition.Center"
                          Width="22"
                          Height="22"/>
                <InfoButton>
                    <MudStack Spacing="2">
                        @if (heldItemInfo is { } itemInfo)
                        {
                            <MudText Typo="@Typo.subtitle2">@itemInfo.Name</MudText>
                            <MudText Typo="@Typo.body2">
                                @(string.IsNullOrEmpty(itemInfo.Description)
                                    ? "No description available."
                                    : itemInfo.Description)
                            </MudText>
                        }
                        else
                        {
                            <MudText Typo="@Typo.subtitle2">@itemText</MudText>
                            <MudText Typo="@Typo.body2">No description available.</MudText>
                        }
                    </MudStack>
                </InfoButton>
            }
            <LegalityIndicator
                Severity="@(GetCheckResult(CheckIdentifier.HeldItem)?.Judgement ?? PKHeX.Core.Severity.Valid)"
                Message="@HumanizeCheckResult(GetCheckResult(CheckIdentifier.HeldItem))"/>
        </MudStack>
    }

    @if (saveGeneration >= 3)
    {
        @if (AppState is { IsHaXEnabled: true } && Pokemon.Format > 3)
        {
            @* DEV_Ability: HaX mode — any ability ID.
               AbilityNumber is independently stored (Gen 6+), so the slot picker
               is only shown for Gen 6+. For Gen 4/5, AbilityNumber.set is a no-op
               in PKHeX.Core (derived from PID), so we omit the picker there. *@
            <MudStack Row
                      AlignItems="@AlignItems.Center"
                      Spacing="1">
                <MudStack Style="flex: 1; min-width: 0;">
                    <MudAutocomplete T="ComboItem"
                                     Label="Ability (HaX — any)"
                                     Variant="@Variant.Outlined"
                                     Value="@GetDevAbilityComboItem()"
                                     ValueChanged="@SetDevAbility"
                                     SearchFunc="@SearchAllAbilities"
                                     ToStringFunc="@(item => item?.Text)"
                                     ResetValueOnEmptyText
                                     CoerceValue/>
                </MudStack>
                @if (Pokemon.Format >= 6)
                {
                    @* Gen 6+: AbilityNumber is independently stored and freely writable *@
                    <MudSelect T="int"
                               Label="Slot"
                               Variant="@Variant.Outlined"
                               Style="max-width: 110px;"
                               Value="@Pokemon.AbilityNumber"
                               ValueChanged="@SetDevAbilityNumber">
                        @foreach (var slot in GetAbilityNumberItems())
                        {
                            <MudSelectItem Value="@slot.Value"
                                           @key="@slot.Value">
                                @slot.Text
                            </MudSelectItem>
                        }
                    </MudSelect>
                }
                <LegalityIndicator
                    Severity="@(GetCheckResult(CheckIdentifier.Ability)?.Judgement ?? PKHeX.Core.Severity.Valid)"
                    Message="@HumanizeCheckResult(GetCheckResult(CheckIdentifier.Ability))"/>
                <InfoButton>
                    <MudStack Spacing="2">
                        <MudText Typo="@Typo.subtitle2">@(abilityInfo?.Name ?? SafeNameLookup.Ability(Pokemon!.Ability))</MudText>
                        <MudText Typo="@Typo.body2">@(abilityInfo is { Description: { Length: > 0 } desc }
                                ? desc
                                : "No description available.")</MudText>
                    </MudStack>
                </InfoButton>
            </MudStack>
        }
        else
        {
            <MudStack Row
                      AlignItems="@AlignItems.Center"
                      Spacing="1">
                <MudStack Style="flex: 1; min-width: 0;">
                    <MudSelect T="int"
                               Label="Ability"
                               Variant="@Variant.Outlined"
                               Value="@GetAbilitySlotIndex()"
                               ValueChanged="@SetAbilitySlot">
                        @foreach (var slot in GetAbilitySlotItems())
                        {
                            <MudSelectItem Value="@slot.Value"
                                           @key="@slot.Value">
                                @slot.Text
                            </MudSelectItem>
                        }
                    </MudSelect>
                </MudStack>
                <LegalityIndicator
                    Severity="@(GetCheckResult(CheckIdentifier.Ability)?.Judgement ?? PKHeX.Core.Severity.Valid)"
                    Message="@HumanizeCheckResult(GetCheckResult(CheckIdentifier.Ability))"/>
                <InfoButton>
                    <MudStack Spacing="2">
                        <MudText Typo="@Typo.subtitle2">@(abilityInfo?.Name ?? SafeNameLookup.Ability(Pokemon!.Ability))</MudText>
                        <MudText Typo="@Typo.body2">@(abilityInfo is { Description: { Length: > 0 } desc }
                                ? desc
                                : "No description available.")</MudText>
                    </MudStack>
                </InfoButton>
            </MudStack>
        }
    }

    @if (saveGeneration >= 3)
    {
        <MudStack Row
                  AlignItems="@AlignItems.Center"
                  Spacing="1">
            <MudStack Style="flex: 1; min-width: 0;">
                <MudSelect Label="Language"
                           Variant="@Variant.Outlined"
                           @bind-Value="@Pokemon.Language"
                           For="@(() => Pokemon.Language)">
                    @foreach (var language in GameInfo.FilteredSources.Languages.DistinctBy(language => language.Value))
                    {
                        <MudSelectItem Value="@language.Value"
                                       @key="@language.Value">
                            <MudText>
                                @language.Text
                            </MudText>
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudStack>
            <LegalityIndicator
                Severity="@(GetCheckResult(CheckIdentifier.Language)?.Judgement ?? PKHeX.Core.Severity.Valid)"
                Message="@HumanizeCheckResult(GetCheckResult(CheckIdentifier.Language))"/>
        </MudStack>
    }

    @if (saveGeneration >= 2)
    {
        <MudNumericField Label="@(Pokemon.IsEgg
                                    ? "Hatch Counter"
                                    : "Friendship")"
                         Variant="@Variant.Outlined"
                         Min="@byte.MinValue"
                         Max="@byte.MaxValue"
                         @bind-Value="@Pokemon.CurrentFriendship"
                         For="@(() => Pokemon.CurrentFriendship)"/>
    }

    <MudStack Row
              Wrap="@Wrap.Wrap">

        @if (saveGeneration >= 2)
        {
            <MudStack Row
                      AlignItems="@AlignItems.Center"
                      Spacing="0">
                <MudCheckBox Label="Is Egg"
                             @bind-Value="@Pokemon.IsEgg"
                             @bind-Value:after="@RefreshService.Refresh"
                             For="@(() => Pokemon.IsEgg)"/>
                <LegalityIndicator
                    Severity="@(GetCheckResult(CheckIdentifier.Egg)?.Judgement ?? PKHeX.Core.Severity.Valid)"
                    Message="@HumanizeCheckResult(GetCheckResult(CheckIdentifier.Egg))"/>
            </MudStack>

            <PokerusComponent Pokemon="Pokemon"/>
        }

        <MudStack Row
                  AlignItems="@AlignItems.Center"
                  Spacing="0">
            <MudCheckBox Label="Shiny"
                         @bind-Value:get="@Pokemon.GetIsShinySafe()"
                         @bind-Value:set="@(isShiny => OnShinySet(isShiny))"
                         For="@(() => Pokemon.IsShiny)"/>
            <LegalityIndicator
                Severity="@(GetCheckResult(CheckIdentifier.Shiny)?.Judgement ?? PKHeX.Core.Severity.Valid)"
                Message="@HumanizeCheckResult(GetCheckResult(CheckIdentifier.Shiny))"/>
        </MudStack>

    </MudStack>
}
