@inherits MudComponentBase

<MudDialog>
    <TitleContent>
        <MudText Typo="@Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.BugReport"
                     Class="mr-2"
                     Style="vertical-align: middle;"/>
            Report a Bug
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3"
                  Class="pa-2">
            @if (!HasSaveFile)
            {
                <MudAlert Severity="@Severity.Info"
                          Dense="true">
                    If your issue is that a file failed to load, make sure you are uploading a
                    <strong>save file</strong> (.sav, .dsv, .bin, etc.) — not a save state (.state)
                    or ROM file. Save states are emulator snapshots and cannot be edited here.
                </MudAlert>
            }
            <MudTextField @bind-Value="@description"
                          Label="What went wrong?"
                          Lines="5"
                          Required
                          Placeholder="Describe the issue in detail. Include: what you were doing, what happened, and what you expected to happen. Mention the game title and any specific Pokémon or field involved."
                          HelperText="@($"Minimum {MinDescriptionLength} characters. {description.Length} entered.")"
                          Validation="@((string v) => (v?.Length ?? 0) >= MinDescriptionLength
                                          ? null
                                          : $"Please provide at least {MinDescriptionLength} characters of detail.")"
                          Variant="@Variant.Outlined"/>
            <MudTextField @bind-Value="@email"
                          Label="Email"
                          InputType="@InputType.Email"
                          Required
                          Validation="@((string v) => EmailValidator.IsValid(v)
                                          ? null
                                          : "Please enter a valid email address.")"
                          Variant="@Variant.Outlined"/>
            <MudTextField @bind-Value="@name"
                          Label="Name"
                          Required
                          Variant="@Variant.Outlined"/>
            <MudSwitch @bind-Value="@attachSaveFile"
                       Label="Attach current save file"
                       Disabled="@(!HasSaveFile)"
                       Color="@Color.Primary"/>
            @if (submitError is not null)
            {
                <MudAlert Severity="@Severity.Error"
                          Dense="true">
                    @submitError
                </MudAlert>
            }
            <MudText Typo="@Typo.caption"
                     Color="@Color.Secondary">
                Reports are sent to our error tracking service to help improve the app.
                @if (HasSaveFile)
                {
                    @:Your current save file will be included to help diagnose the issue.
                }
            </MudText>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@Cancel"
                   Variant="@Variant.Text">
            Cancel
        </MudButton>
        <MudButton OnClick="@Submit"
                   Color="@Color.Primary"
                   Variant="@Variant.Filled"
                   Disabled="@(description.Length < MinDescriptionLength || !IsEmailValid || string.IsNullOrWhiteSpace(name))">
            Submit Report
        </MudButton>
    </DialogActions>
</MudDialog>
