@inherits BasePkmdsComponent

<MudDialog>
    <TitleContent>
        <MudText Typo="@Typo.h6">Minior Form</MudText>
    </TitleContent>
    <DialogContent>
        @if (Pokemon is not null)
        {
            var forms = FormConverter.GetFormList(Pokemon.Species, GameInfo.Strings.types, GameInfo.Strings.forms,
                GameInfo.GenderSymbolUnicode, Pokemon.Context);

            <MudText Typo="@Typo.subtitle2"
                     Class="mb-1">Meteor Form
            </MudText>
            <MudStack Row
                      Wrap="@Wrap.Wrap"
                      Spacing="1"
                      Class="mb-3">
                @for (byte i = 0; i < MiniorMeteorCount; i++)
                {
                    var formIdx = i;
                    var label = formIdx < forms.Length
                        ? forms[formIdx]
                        : $"Meteor {formIdx}";
                    var isSelected = formIdx == selectedForm;
                    <MudTooltip Text="@label">
                        <MudPaper Class="pa-1 cursor-pointer"
                                  Style="@(isSelected
                                             ? "border: 2px solid var(--mud-palette-primary);"
                                             : "border: 2px solid transparent;")"
                                  Elevation="@(isSelected
                                                 ? 4
                                                 : 0)"
                                  @onclick="@(() => selectedForm = formIdx)">
                            <MudImage Src="@ImageHelper.GetPokemonSpriteFilenameForForm(Pokemon.Species, Pokemon.Context, formIdx)"
                                      Alt="@label"
                                      ObjectFit="@ObjectFit.Contain"
                                      Width="56"
                                      Height="56"/>
                            <MudText Typo="@Typo.caption"
                                     Align="@Align.Center"
                                     Style="max-width:56px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                @label
                            </MudText>
                        </MudPaper>
                    </MudTooltip>
                }
            </MudStack>

            <MudText Typo="@Typo.subtitle2"
                     Class="mb-1">Core Form
            </MudText>
            <MudStack Row
                      Wrap="@Wrap.Wrap"
                      Spacing="1">
                @for (var i = MiniorMeteorCount; i < MiniorMeteorCount + MiniorCoreCount; i++)
                {
                    var formIdx = i;
                    var label = formIdx < forms.Length
                        ? forms[formIdx]
                        : $"Core {formIdx - MiniorMeteorCount}";
                    var isSelected = formIdx == selectedForm;
                    <MudTooltip Text="@label">
                        <MudPaper Class="pa-1 cursor-pointer"
                                  Style="@(isSelected
                                             ? "border: 2px solid var(--mud-palette-primary);"
                                             : "border: 2px solid transparent;")"
                                  Elevation="@(isSelected
                                                 ? 4
                                                 : 0)"
                                  @onclick="@(() => selectedForm = formIdx)">
                            <MudImage Src="@ImageHelper.GetPokemonSpriteFilenameForForm(Pokemon.Species, Pokemon.Context, formIdx)"
                                      Alt="@label"
                                      ObjectFit="@ObjectFit.Contain"
                                      Width="56"
                                      Height="56"/>
                            <MudText Typo="@Typo.caption"
                                     Align="@Align.Center"
                                     Style="max-width:56px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                @label
                            </MudText>
                        </MudPaper>
                    </MudTooltip>
                }
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@Cancel"
                   Variant="@Variant.Outlined">Cancel
        </MudButton>
        <MudButton OnClick="@Confirm"
                   Variant="@Variant.Filled"
                   Color="@Color.Primary">Confirm
        </MudButton>
    </DialogActions>
</MudDialog>
