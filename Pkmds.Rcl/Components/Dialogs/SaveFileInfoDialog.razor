<MudDialog>
    <TitleContent>
        <MudText Typo="@Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Info"
                     Class="mr-2"
                     Style="vertical-align: middle;"/>
            Save File Info
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (SaveFile is null)
        {
            <MudText Color="@Color.Secondary">No save file loaded.</MudText>
        }
        else
        {
            <MudStack Spacing="4"
                      Class="pa-2"
                      Style="min-width: 420px;">

                <!-- File Info -->
                <MudStack Spacing="1">
                    <MudText Typo="@Typo.subtitle1"
                             Color="@Color.Primary">
                        File Info
                    </MudText>
                    <MudSimpleTable Dense
                                    Hover
                                    Elevation="0"
                                    Style="background: transparent;">
                        <tbody>
                        <tr>
                            <td><strong>Save Type</strong></td>
                            <td>@SaveFile.GetType().Name</td>
                        </tr>
                        <tr>
                            <td><strong>Generation</strong></td>
                            <td>@SaveFile.Generation</td>
                        </tr>
                        <tr>
                            <td><strong>Game</strong></td>
                            <td>@SaveFileNameDisplay.FriendlyGameName(SaveFile.Version)</td>
                        </tr>
                        @if (RevisionString is not null)
                        {
                            <tr>
                                <td><strong>Revision</strong></td>
                                <td>@RevisionString</td>
                            </tr>
                        }
                        <tr>
                            <td><strong>File Size</strong></td>
                            <td>@FormatSize(FileSize)</td>
                        </tr>
                        @if (SaveFile.Metadata.HasHeader)
                        {
                            <tr>
                                <td><strong>Header</strong></td>
                                <td>Present</td>
                            </tr>
                        }
                        @if (SaveFile.Metadata.HasFooter)
                        {
                            <tr>
                                <td><strong>Footer</strong></td>
                                <td>Present</td>
                            </tr>
                        }
                        </tbody>
                    </MudSimpleTable>
                </MudStack>

                <MudDivider/>

                <!-- Checksum Status -->
                <MudStack Spacing="1">
                    <MudText Typo="@Typo.subtitle1"
                             Color="@Color.Primary">
                        Checksum Status
                    </MudText>
                    <MudAlert Severity="@(SaveFile.ChecksumsValid
                                            ? Severity.Success
                                            : Severity.Error)"
                              Variant="@Variant.Outlined"
                              Dense
                              NoIcon="false">
                        @(SaveFile.ChecksumsValid
                            ? "All checksums are valid."
                            : "One or more checksums are invalid.")
                    </MudAlert>
                    @if (!string.IsNullOrWhiteSpace(SaveFile.ChecksumInfo))
                    {
                        <MudText Typo="@Typo.caption"
                                 Style="font-family: monospace; white-space: pre-wrap;">@SaveFile.ChecksumInfo</MudText>
                    }
                </MudStack>

                <MudDivider/>

                <!-- Encryption & Export Status -->
                <MudStack Spacing="1">
                    <MudText Typo="@Typo.subtitle1"
                             Color="@Color.Primary">
                        Encryption &amp; Export
                    </MudText>
                    <MudSimpleTable Dense
                                    Hover
                                    Elevation="0"
                                    Style="background: transparent;">
                        <tbody>
                        <tr>
                            <td><strong>Format Encryption</strong></td>
                            <td>@GetEncryptionDescription()</td>
                        </tr>
                        <tr>
                            <td><strong>Exportable</strong></td>
                            <td>
                                @if (SaveFile.State.Exportable)
                                {
                                    <MudChip T="@string"
                                             Size="@Size.Small"
                                             Color="@Color.Success"
                                             Variant="@Variant.Outlined">
                                        Yes
                                    </MudChip>
                                }
                                else
                                {
                                    <MudChip T="@string"
                                             Size="@Size.Small"
                                             Color="@Color.Warning"
                                             Variant="@Variant.Outlined">
                                        No (blank save)
                                    </MudChip>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td><strong>Modified</strong></td>
                            <td>
                                @if (SaveFile.State.Edited)
                                {
                                    <MudChip T="@string"
                                             Size="@Size.Small"
                                             Color="@Color.Info"
                                             Variant="@Variant.Outlined">
                                        Yes
                                    </MudChip>
                                }
                                else
                                {
                                    <MudChip T="@string"
                                             Size="@Size.Small"
                                             Color="@Color.Default"
                                             Variant="@Variant.Outlined">
                                        No
                                    </MudChip>
                                }
                            </td>
                        </tr>
                        </tbody>
                    </MudSimpleTable>
                </MudStack>

                <MudDivider/>

                <!-- Storage Summary -->
                <MudStack Spacing="1">
                    <MudText Typo="@Typo.subtitle1"
                             Color="@Color.Primary">
                        Storage
                    </MudText>
                    <MudSimpleTable Dense
                                    Hover
                                    Elevation="0"
                                    Style="background: transparent;">
                        <tbody>
                        @if (SaveFile.HasBox)
                        {
                            <tr>
                                <td><strong>Boxes</strong></td>
                                <td>@SaveFile.BoxCount (@SaveFile.BoxSlotCount slots each)</td>
                            </tr>
                            <tr>
                                <td><strong>Total Box Slots</strong></td>
                                <td>@SaveFile.SlotCount</td>
                            </tr>
                        }
                        <tr>
                            <td><strong>Party</strong></td>
                            <td>@SaveFile.PartyCount / 6</td>
                        </tr>
                        @if (SaveFile.HasPokeDex)
                        {
                            <tr>
                                <td><strong>Seen</strong></td>
                                <td>@SaveFile.SeenCount</td>
                            </tr>
                            <tr>
                                <td><strong>Caught</strong></td>
                                <td>@SaveFile.CaughtCount</td>
                            </tr>
                        }
                        </tbody>
                    </MudSimpleTable>
                </MudStack>

            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@Close"
                   Variant="@Variant.Text">
            Close
        </MudButton>
    </DialogActions>
</MudDialog>
