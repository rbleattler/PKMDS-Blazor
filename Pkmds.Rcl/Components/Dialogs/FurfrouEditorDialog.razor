@inherits BasePkmdsComponent

<MudDialog>
    <TitleContent>
        <MudText Typo="@Typo.h6">Furfrou Trim Style</MudText>
    </TitleContent>
    <DialogContent>
        @if (Pokemon is not null)
        {
            var forms = FormConverter.GetFormList(Pokemon.Species, GameInfo.Strings.types, GameInfo.Strings.forms,
                GameInfo.GenderSymbolUnicode, Pokemon.Context);

            <MudStack Row
                      Wrap="@Wrap.Wrap"
                      Spacing="1"
                      Class="mb-3">
                @for (byte i = 0; i < forms.Length; i++)
                {
                    if (string.IsNullOrEmpty(forms[i]))
                    {
                        continue;
                    }

                    var formIdx = i;
                    var isSelected = formIdx == selectedForm;
                    <MudTooltip Text="@forms[formIdx]">
                        <MudPaper Class="pa-1 cursor-pointer"
                                  Style="@(isSelected
                                             ? "border: 2px solid var(--mud-palette-primary);"
                                             : "border: 2px solid transparent;")"
                                  Elevation="@(isSelected
                                                 ? 4
                                                 : 0)"
                                  @onclick="@(() => SelectForm(formIdx))">
                            <MudImage Src="@ImageHelper.GetPokemonSpriteFilenameForForm(Pokemon.Species, Pokemon.Context, formIdx)"
                                      Alt="@forms[formIdx]"
                                      ObjectFit="@ObjectFit.Contain"
                                      Width="56"
                                      Height="56"/>
                            <MudText Typo="@Typo.caption"
                                     Align="@Align.Center"
                                     Style="max-width:56px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                @forms[formIdx]
                            </MudText>
                        </MudPaper>
                    </MudTooltip>
                }
            </MudStack>

            @if (selectedForm != 0 && Pokemon is IFormArgument)
            {
                <MudNumericField T="@uint"
                                 Label="Days remaining in trim (0–5)"
                                 Variant="@Variant.Outlined"
                                 Min="@((uint)0)"
                                 Max="@((uint)5)"
                                 @bind-Value="@daysRemaining"/>
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@Cancel"
                   Variant="@Variant.Outlined">Cancel
        </MudButton>
        <MudButton OnClick="@Confirm"
                   Variant="@Variant.Filled"
                   Color="@Color.Primary">Confirm
        </MudButton>
    </DialogActions>
</MudDialog>
