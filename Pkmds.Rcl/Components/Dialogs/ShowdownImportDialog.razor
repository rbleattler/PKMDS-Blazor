<MudDialog>
    <TitleContent>
        <MudText Typo="@Typo.h6">Import from Showdown / PokePaste</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">

            <MudTextField @bind-Value="inputText"
                          Label="Showdown text or PokePaste URL"
                          Lines="10"
                          Variant="@Variant.Outlined"
                          Placeholder="Paste Showdown text or a PokePaste URL (https://pokepast.es/...)…"
                          Disabled="@(isFetching || isParsing)"/>

            @if (!string.IsNullOrEmpty(fetchError))
            {
                <MudAlert Severity="@Severity.Error"
                          Dense="true">
                    @fetchError
                </MudAlert>
            }

            @if (pasteInfo is not null)
            {
                <MudText Typo="@Typo.caption"
                         Color="@Color.Secondary">
                    @pasteInfo
                </MudText>
            }

            <MudStack Row
                      Spacing="2"
                      AlignItems="@AlignItems.Center">
                @if (IsUrl)
                {
                    <MudButton OnClick="@FetchUrlAsync"
                               Variant="@Variant.Filled"
                               StartIcon="@Icons.Material.Filled.Download"
                               Color="@Color.Primary"
                               Disabled="@(isFetching || isParsing)">
                        @if (isFetching)
                        {
                            <MudProgressCircular Size="@Size.Small"
                                                 Indeterminate="true"
                                                 Class="mr-2"/>
                            @:Fetching…
                        }
                        else
                        {
                            @:Fetch
                        }
                    </MudButton>
                }
                <MudButton OnClick="@ParseTextAsync"
                           Variant="@Variant.Filled"
                           Color="@Color.Primary"
                           StartIcon="@Icons.Material.Filled.Search"
                           Disabled="@(string.IsNullOrWhiteSpace(inputText) || isFetching || isParsing)">
                    @if (isParsing)
                    {
                        <MudProgressCircular Size="@Size.Small"
                                             Indeterminate="true"
                                             Class="mr-2"/>
                        @:Analyzing…
                    }
                    else
                    {
                        @:Parse
                    }
                </MudButton>
            </MudStack>

            @if (parsedEntries.Count > 0)
            {
                <MudDivider/>

                <MudText Typo="@Typo.subtitle2">
                    Preview — @parsedEntries.Count Pokémon
                </MudText>

                <MudList T="ParsedEntry"
                         Dense="true">
                    @foreach (var entry in parsedEntries)
                    {
                        <MudListItem T="ParsedEntry">
                            <MudStack Row
                                      AlignItems="@AlignItems.Center"
                                      Spacing="1">
                                @if (entry.Status is { } status)
                                {
                                    <MudTooltip Text="@GetStatusTooltip(entry)">
                                        <MudIcon Icon="@LegalityUi.GetStatusIcon(status)"
                                                 Color="@LegalityUi.GetStatusColor(status)"
                                                 Size="@Size.Small"/>
                                    </MudTooltip>
                                }
                                <MudText>@GetSetSummary(entry.Set)</MudText>
                                @if (entry.Set.InvalidLines.Count > 0)
                                {
                                    <MudTooltip Text="@GetWarnings(entry.Set)">
                                        <MudIcon Icon="@Icons.Material.Filled.Warning"
                                                 Color="@Color.Warning"
                                                 Size="@Size.Small"/>
                                    </MudTooltip>
                                }
                            </MudStack>
                        </MudListItem>
                    }
                </MudList>

                <MudDivider/>

                <MudText Typo="@Typo.subtitle2">Import Target</MudText>

                <MudSelect T="bool"
                           @bind-Value="importToParty"
                           Label="Destination"
                           Variant="@Variant.Outlined">
                    <MudSelectItem T="bool"
                                   Value="@false">
                        First available box slot
                    </MudSelectItem>
                    <MudSelectItem T="bool"
                                   Value="@true">
                        Party
                    </MudSelectItem>
                </MudSelect>
            }

        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@Cancel"
                   Variant="@Variant.Filled"
                   Color="@Color.Default"
                   StartIcon="@Icons.Material.Filled.Clear">
            Cancel
        </MudButton>
        <MudButton OnClick="@ImportAsync"
                   Variant="@Variant.Filled"
                   Color="@Color.Primary"
                   StartIcon="@Icons.Material.Filled.FileUpload"
                   Disabled="@(parsedEntries.Count == 0 || isParsing || AppState.SaveFile is null)">
            Import
        </MudButton>
    </DialogActions>
</MudDialog>
