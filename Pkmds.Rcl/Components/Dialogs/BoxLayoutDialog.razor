@inherits BasePkmdsComponent

<MudDialog>
    <TitleContent>
        <MudText Typo="@Typo.h6">Box Layout</MudText>
    </TitleContent>
    <DialogContent>
        @if (AppState.SaveFile is { } saveFile)
        {
            <MudGrid>
                <MudItem xs="5">
                    <div class="d-flex gap-1 mb-1">
                        <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward"
                                       Size="@Size.Small"
                                       Variant="@Variant.Outlined"
                                       Disabled="@(selectedBoxIndex == 0)"
                                       OnClick="@MoveBoxUp"
                                       title="Move box up"/>
                        <MudIconButton Icon="@Icons.Material.Filled.ArrowDownward"
                                       Size="@Size.Small"
                                       Variant="@Variant.Outlined"
                                       Disabled="@(selectedBoxIndex >= boxNames.Length - 1)"
                                       OnClick="@MoveBoxDown"
                                       title="Move box down"/>
                    </div>
                    <MudPaper Outlined
                              Class="overflow-y-auto"
                              Style="max-height: 380px;">
                        <MudList T="@int"
                                 SelectedValue="@selectedBoxIndex"
                                 SelectedValueChanged="@(idx => SelectBox(idx))"
                                 Dense>
                            @for (var i = 0; i < boxNames.Length; i++)
                            {
                                var boxIndex = i;
                                <MudListItem T="@int"
                                             Value="@boxIndex">
                                    @($"Box {boxIndex + 1}: {boxNames[boxIndex]} ({GetBoxPokemonCount(boxIndex)}/{saveFile.BoxSlotCount})")
                                </MudListItem>
                            }
                        </MudList>
                    </MudPaper>
                </MudItem>

                <MudItem xs="7">
                    @if (supportsNameRead)
                    {
                        <MudTextField T="@string"
                                      @key="@($"name-{selectedBoxIndex}")"
                                      Value="@boxNames[selectedBoxIndex]"
                                      ValueChanged="@(v => OnBoxNameChanged(v))"
                                      Label="Box Name"
                                      Immediate
                                      MaxLength="@GetBoxNameMaxLength()"
                                      ReadOnly="@(!supportsNameWrite)"
                                      Class="mb-3"/>
                    }

                    @if (supportsWallpaper && wallpaperNameList.Length > 0)
                    {
                        <MudSelect T="@int"
                                   @key="@($"wallpaper-{selectedBoxIndex}")"
                                   Value="@wallpaperIds[selectedBoxIndex]"
                                   ValueChanged="@(id => OnWallpaperChanged(id))"
                                   Label="Wallpaper"
                                   Class="mb-3">
                            @for (var i = 0; i < wallpaperNameList.Length; i++)
                            {
                                var localId = i;
                                <MudSelectItem Value="@localId">@wallpaperNameList[localId]</MudSelectItem>
                            }
                        </MudSelect>

                        @if (!string.IsNullOrEmpty(wallpaperSpriteUrl))
                        {
                            <img src="@wallpaperSpriteUrl"
                                 alt="Wallpaper preview"
                                 class="w-full rounded mb-3"/>
                        }
                    }

                    @if (showUnlocked)
                    {
                        <MudSelect T="@int"
                                   Value="@boxesUnlocked"
                                   ValueChanged="@(v => OnBoxesUnlockedChanged(v))"
                                   Label="Unlocked"
                                   Class="mb-3">
                            @for (var i = 0; i <= saveFile.BoxCount; i++)
                            {
                                var localI = i;
                                <MudSelectItem Value="@localI">@localI</MudSelectItem>
                            }
                        </MudSelect>
                    }

                    @if (boxFlags.Length > 0)
                    {
                        <MudText Typo="@Typo.caption"
                                 Class="mb-1">Flags
                        </MudText>
                        @for (var i = 0; i < boxFlags.Length; i++)
                        {
                            var idx = i;
                            <MudNumericField T="@byte"
                                             Value="@boxFlags[idx]"
                                             ValueChanged="@(v => OnFlagChanged(idx, v))"
                                             Label="@($"Flag {idx}")"
                                             Min="0"
                                             Max="255"
                                             Class="mb-2"/>
                        }
                    }
                </MudItem>
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@Close"
                   Variant="@Variant.Outlined">
            Close
        </MudButton>
    </DialogActions>
</MudDialog>
