@inherits BasePkmdsComponent

<MudDialog>
    <DialogContent>
        @if (Pokemon is not null)
        {
            var forms = FormConverter.GetFormList(Pokemon.Species, GameInfo.Strings.types, GameInfo.Strings.forms,
                GameInfo.GenderSymbolUnicode, Pokemon.Context);

            <MudSwitch T="bool"
                       @bind-Value="isPreviewShiny"
                       Color="@Color.Warning"
                       Label="Shiny Preview"
                       Class="mb-2"/>
            <MudStack Row
                      Wrap="@Wrap.Wrap"
                      Spacing="2"
                      Justify="@Justify.Center">
                @for (byte i = 0; i < forms.Length; i++)
                {
                    if (string.IsNullOrEmpty(forms[i]))
                    {
                        continue;
                    }

                    var formIdx = i;
                    var isSelected = formIdx == selectedForm;
                    <MudPaper Class="pa-2 cursor-pointer"
                              Style="@(isSelected
                                         ? "border: 2px solid var(--mud-palette-primary); min-width:80px;"
                                         : "border: 2px solid transparent; min-width:80px;")"
                              Elevation="@(isSelected
                                             ? 4
                                             : 1)"
                              @onclick="@(() => selectedForm = formIdx)">
                        <MudStack AlignItems="@AlignItems.Center"
                                  Spacing="0">
                            <img src="@(ImageHelper.GetPokeApiHomeSpriteUrl(Pokemon.Species, formIdx, null, isPreviewShiny, Pokemon.Gender)
                                         ?? ImageHelper.GetPokemonSpriteFilenameForForm(Pokemon.Species, Pokemon.Context, formIdx))"
                                 alt="@forms[formIdx]"
                                 style="width:64px; height:64px; object-fit:contain; display:block;"
                                 onerror="this.onerror=null; this.src='@ImageHelper.GetPokemonSpriteFilenameForForm(Pokemon.Species, Pokemon.Context, formIdx)'"/>
                            <MudText Typo="@Typo.body2"
                                     Align="@Align.Center">@forms[formIdx]</MudText>
                        </MudStack>
                    </MudPaper>
                }
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@Cancel"
                   Variant="@Variant.Outlined">Cancel
        </MudButton>
        <MudButton OnClick="@Confirm"
                   Variant="@Variant.Filled"
                   Color="@Color.Primary">Confirm
        </MudButton>
    </DialogActions>
</MudDialog>
