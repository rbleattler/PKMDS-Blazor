@* Transparent full-screen overlay — sits below the popover (z-index 1199) so
   tapping anywhere outside the popover closes it on both mouse and touch. *@
@if (_open)
{
    <div @onclick="Close"
         style="position:fixed;inset:0;z-index:1199;cursor:default;" />
}

<span @ref="_anchor" style="position:relative;display:inline-flex;align-items:center;">
    <MudIconButton Icon="@Icons.Material.Outlined.Info"
                   Size="@Size.Small"
                   Color="@Color.Default"
                   OnClick="@Toggle"
                   title="More info"
                   aria-label="More info"
                   aria-expanded="@_open" />
    <MudPopover Open="@_open"
                AnchorOrigin="Origin.BottomLeft"
                TransformOrigin="Origin.TopLeft"
                OverflowBehavior="OverflowBehavior.FlipAlways"
                Paper="true"
                Class="pa-3"
                Style="max-width:320px;max-height:400px;overflow-y:auto;z-index:1200;">
        @ChildContent
    </MudPopover>
</span>

@code {
    private bool _open;
    private ElementReference _anchor;

    /// <summary>The content to display inside the info popover.</summary>
    [Parameter, EditorRequired]
    public RenderFragment ChildContent { get; set; } = default!;

    private void Toggle() => _open = !_open;
    private void Close() => _open = false;
}
